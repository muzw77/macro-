-- ─────────────────────────────────────────────────────────────────────
-- HELPERS
-- ─────────────────────────────────────────────────────────────────────

local function isAlive(inst) return inst ~= nil and inst.Parent ~= nil end
local function safeGet(fn) local ok,v = pcall(fn) return ok and v or nil end
local function getChar()  return player.Character end
local function getHum(c)  return c and c:FindFirstChildOfClass("Humanoid") end
local function getRoot(c) return c and c:FindFirstChild("HumanoidRootPart") end

local function resolvePos(inst)
    if not isAlive(inst) then return nil end
    return safeGet(function()
        if inst:IsA("BasePart") then return inst.Position end
        if inst:IsA("Model") then
            if inst.PrimaryPart then return inst.PrimaryPart.Position end
            local bp = inst:FindFirstChildWhichIsA("BasePart", true)
            return bp and bp.Position
        end
    end)
end

local function resolvePath(pathTable)
    local cur = workspace
    for _, key in ipairs(pathTable) do
        cur = cur:FindFirstChild(key)
        if not cur then return nil end
    end
    return cur
end

local function findClover()
    for _, v in ipairs(workspace:GetDescendants()) do
        if v.Name:lower() == CLOVER_NAME and (v:IsA("Model") or v:IsA("BasePart")) then
            return v
        end
    end
    return nil
end

local function isGapBelow(position)
    local rayDir = Vector3.new(0, -(GAP_DEPTH_THRESHOLD + 0.5), 0)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local char = getChar()
    if char then params.FilterDescendantsInstances = {char} end
    local offsets = {
        Vector3.new(0,0.5,0), Vector3.new(0.4,0.5,0), Vector3.new(-0.4,0.5,0),
        Vector3.new(0,0.5,0.4), Vector3.new(0,0.5,-0.4),
    }
    for _, offset in ipairs(offsets) do
        if workspace:Raycast(position + offset, rayDir, params) then return false end
    end
    return true
end

local function getGapInfo(fromPos, toPos)
    local horizontalDist = Vector3.new(toPos.X-fromPos.X, 0, toPos.Z-fromPos.Z).Magnitude
    local midPos = (fromPos + toPos) / 2
    if not isGapBelow(toPos) and not isGapBelow(midPos) then return nil end
    if horizontalDist <= MAX_JUMPABLE_GAP then return horizontalDist end
    return false
end

local function makePathFolder(waypoints, color)
    local folder = Instance.new("Folder")
    folder.Name  = "ActivePath"
    pcall(function()
        for i, wp in ipairs(waypoints) do
            local p = Instance.new("Part")
            p.Shape        = Enum.PartType.Ball
            p.Size         = Vector3.new(0.6,0.6,0.6)
            p.Position     = wp.Position
            p.Anchored     = true
            p.CanCollide   = false
            p.CastShadow   = false
            p.Transparency = shared.dev and 0 or 1
            p.Material     = Enum.Material.SmoothPlastic
            local prevPos  = (i > 1) and waypoints[i-1].Position or wp.Position
            local gapInfo  = getGapInfo(prevPos, wp.Position)
            if gapInfo then p.Color = GAP_COLOR
            elseif wp.Action == Enum.PathWaypointAction.Jump then p.Color = JUMP_COLOR
            else p.Color = color end
            p.Parent = folder
        end
    end)
    folder.Parent = workspace
    local function cleanup()
        task.spawn(function() pcall(function() if folder.Parent then folder:Destroy() end end) end)
    end
    return folder, cleanup
end

local function doJump(hum)
    if hum
        and hum:GetState() ~= Enum.HumanoidStateType.Jumping
        and hum:GetState() ~= Enum.HumanoidStateType.Freefall
    then
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end

local function doGapJump(hum, root, targetPos)
    if not hum or not root then return false end
    local dir = (Vector3.new(targetPos.X, root.Position.Y, targetPos.Z) - root.Position).Unit
    if PARKOUR_JUMP_BOOST then
        hum:MoveTo(root.Position + dir * 1.5)
        task.wait(0.08)
    end
    doJump(hum)
    hum:MoveTo(targetPos)
    local t0 = tick()
    while tick() - t0 < 2.5 do
        task.wait()
        local state = hum:GetState()
        if state ~= Enum.HumanoidStateType.Jumping and state ~= Enum.HumanoidStateType.Freefall then return true end
        hum:MoveTo(targetPos)
    end
    return false
end

local function respawnAndWait()
    local humanoid = getHum(getChar())
    if humanoid then humanoid.Health = 0 end
    task.wait(0.5)
    local t0 = tick()
    while tick() - t0 < 10 do
        local c = getChar()
        local hum = getHum(c)
        local root = getRoot(c)
        if c and hum and root and hum.Health > 0 then break end
        task.wait(0.2)
    end
    task.wait(0.3)
end

local function findLadderNear(root)
    local nearby = workspace:GetPartBoundsInBox(CFrame.new(root.Position), Vector3.new(4,6,4))
    for _, part in ipairs(nearby) do
        if part:IsA("BasePart") and not part:IsA("TrussPart") and string.find(part.Name:lower(), "ladder") then
            return part
        end
    end
    return nil
end

local function climbLadder(hum, root, ladder)
    local topY   = ladder.Position.Y + ladder.Size.Y / 2 + 3
    local topPos = Vector3.new(ladder.Position.X, topY, ladder.Position.Z)
    hum:MoveTo(Vector3.new(ladder.Position.X, root.Position.Y, ladder.Position.Z))
    task.wait(0.3)
    local t0 = tick()
    local lastY, stuckT = root.Position.Y, tick()
    while tick() - t0 < 10 do
        task.wait(0.1)
        if root.Position.Y >= topY - 1.5 then return true end
        hum:MoveTo(topPos)
        if root.Position.Y > lastY + 0.1 then
            lastY = root.Position.Y stuckT = tick()
        elseif tick() - stuckT > 2 then
            return false
        end
    end
    return false
end

local function pathHasGap(waypoints)
    for i = 2, #waypoints do
        if getGapInfo(waypoints[i-1].Position, waypoints[i].Position) ~= nil then return true end
    end
    return false
end

local function computeSafePath(fromPos, toPos, extraRadius)
    local params = {
        AgentHeight     = PATH_PARAMS.AgentHeight,
        AgentRadius     = PATH_PARAMS.AgentRadius + (extraRadius or 0),
        AgentCanJump    = PATH_PARAMS.AgentCanJump,
        AgentJumpHeight = PATH_PARAMS.AgentJumpHeight,
        WaypointSpacing = PATH_PARAMS.WaypointSpacing,
    }
    local path = PathfindingService:CreatePath(params)
    local ok = pcall(function() path:ComputeAsync(fromPos, toPos) end)
    if not ok or path.Status ~= Enum.PathStatus.Success then return nil end
    return path
end

-- ─────────────────────────────────────────────────────────────────────
-- STEP TO WAYPOINT  (shared by eggs, buffs, and clover)
-- ─────────────────────────────────────────────────────────────────────

local function stepToWaypoint(hum, root, wp, prevPos)
    if not hum or not root then return "fail" end
    local fromPos = prevPos or root.Position
    local gapInfo = getGapInfo(fromPos, wp.Position)
    if gapInfo == false then return "gaptoowide"
    elseif gapInfo then
        return doGapJump(hum, root, wp.Position) and "reached" or "gapfail"
    end

    hum:MoveTo(wp.Position)
    local result, startT = nil, tick()
    local lastPos, lastPosTime = root.Position, tick()
    local PROGRESS_CHECK_INTERVAL, MIN_PROGRESS = 0.6, 0.8

    local moveConn = hum.MoveToFinished:Connect(function(reached)
        if result == nil then result = reached and "reached" or "timeout" end
    end)

    while result == nil do
        task.wait()
        if not isRunning() then result = "stopped" break end
        if tick() - startT > WAYPOINT_TIMEOUT then result = "timeout" break end
        if (root.Position - wp.Position).Magnitude < REACH_DIST then
            result = "reached" lastMoveTick = tick() stuckCheckCount = 0 break
        end

        local now = tick()
        if now - lastPosTime > PROGRESS_CHECK_INTERVAL then
            local moved = (root.Position - lastPos).Magnitude
            if moved < MIN_PROGRESS then
                stuckCheckCount += 1
                warn("[EggBot] Stuck check " .. stuckCheckCount .. "/" .. STUCK_RESET_THRESHOLD)
                if stuckCheckCount >= STUCK_RESET_THRESHOLD then
                    stuckCheckCount = 0
                    moveConn:Disconnect()
                    respawnAndWait()
                    return "stuck_reset"
                end
                local ladder = findLadderNear(root)
                if ladder then
                    moveConn:Disconnect()
                    result = climbLadder(hum, root, ladder) and "reached" or "timeout"
                    break
                end
                local surpriseGap = getGapInfo(root.Position, root.Position + (wp.Position - root.Position).Unit * 3)
                if surpriseGap and surpriseGap ~= false then
                    if doGapJump(hum, root, wp.Position) then stuckCheckCount = 0 result = "reached" break end
                else
                    local awayDir = (root.Position - wp.Position).Unit
                    hum:MoveTo(root.Position + Vector3.new(awayDir.X*3, 0, awayDir.Z*3))
                    task.wait(0.4)
                    doJump(hum) task.wait(0.05)
                    hum:MoveTo(wp.Position)
                end
            else
                stuckCheckCount = 0
            end
            lastPos = root.Position lastPosTime = now
        end
    end

    moveConn:Disconnect()
    return result
end

-- ─────────────────────────────────────────────────────────────────────
-- GENERIC WALK-TO  (used for both buffs and clover)
-- Returns true if touched, false if all attempts failed
-- ─────────────────────────────────────────────────────────────────────

local function walkToTarget(targetInst, touchDist, label, maxAttempts)
    local char = getChar()
    local hum  = getHum(char)
    local root = getRoot(char)
    if not hum or not root then return false end

    maxAttempts = maxAttempts or 3

    for attempt = 1, maxAttempts do
        if not isRunning() then return false end

        local targetPos = resolvePos(targetInst)
        if not targetPos then
            warn("[EggBot] " .. label .. " disappeared, aborting")
            return false
        end

        local path = computeSafePath(root.Position, targetPos, 0)
        if not path then
            warn("[EggBot] " .. label .. " path failed attempt " .. attempt)
            task.wait(0.3)
            continue
        end

        local waypoints = path:GetWaypoints()
        local broken    = false

        for i, wp in ipairs(waypoints) do
            if not isRunning() then broken = true break end
            local prevPos = (i > 1) and waypoints[i-1].Position or root.Position
            if wp.Action == Enum.PathWaypointAction.Jump then doJump(hum) end

            local stepResult = stepToWaypoint(hum, root, wp, prevPos)
            if stepResult ~= "reached" then broken = true break end

            -- close enough = touched
            if (root.Position - targetPos).Magnitude <= touchDist then
                warn("[EggBot] Touched: " .. label)
                return true
            end
        end

        if not broken then
            -- finished all waypoints — do a final distance check
            local finalPos = resolvePos(targetInst)
            if finalPos and (root.Position - finalPos).Magnitude <= touchDist + 2 then
                warn("[EggBot] Touched (end of path): " .. label)
                return true
            end
        end

        warn("[EggBot] " .. label .. " attempt " .. attempt .. " failed, retrying...")
        task.wait(0.3)
    end

    warn("[EggBot] " .. label .. " skipped after " .. maxAttempts .. " failed attempts")
    return false
end

-- ─────────────────────────────────────────────────────────────────────
-- BUFF COLLECTION  (ObbyBlessing, every 2 min, 3 tries)
-- ─────────────────────────────────────────────────────────────────────

local function runBuffCollection()
    if not buffsEnabled() then return end
    if isCollectingPickup then return end

    isCollectingPickup = true
    warn("[EggBot] Starting buff collection run (pausing eggs)")

    for _, buffDef in ipairs(BUFF_GIVERS) do
        if not buffsEnabled() or not isRunning() then break end

        local buffPart = resolvePath(buffDef.path)
        if not buffPart then
            warn("[EggBot] BuffGiver not found: " .. buffDef.name)
            continue
        end

        local success = walkToTarget(buffPart, BUFF_TOUCH_DIST, "Buff:" .. buffDef.name, BUFF_MAX_ATTEMPTS)
        if success then
            warn("[EggBot] Buff collected: " .. buffDef.name)
        else
            warn("[EggBot] Buff skipped (all attempts failed): " .. buffDef.name)
        end
    end

    lastBuffTime       = tick()
    isCollectingPickup = false
    warn("[EggBot] Buff run done, resuming eggs")
    processQueue()
end

-- ─────────────────────────────────────────────────────────────────────
-- CLOVER COLLECTION  (every 4 min, 3 tries)
-- ─────────────────────────────────────────────────────────────────────

local function runCloverCollection()
    if not cloverEnabled() then return end
    if isCollectingPickup then return end

    local clover = findClover()
    if not clover then
        warn("[EggBot] No clover found in workspace")
        lastCloverTime = tick()
        return
    end

    isCollectingPickup = true
    warn("[EggBot] Starting clover collection run (pausing eggs)")

    local success = walkToTarget(clover, CLOVER_TOUCH_DIST, "Clover", 3)
    if success then
        warn("[EggBot] Clover collected!")
    else
        warn("[EggBot] Clover skipped (all attempts failed)")
    end

    lastCloverTime     = tick()
    isCollectingPickup = false
    warn("[EggBot] Clover run done, resuming eggs")
    processQueue()
end

-- ─────────────────────────────────────────────────────────────────────
-- PICKUP SCHEDULER  (runs independently, checks timers every second)
-- ─────────────────────────────────────────────────────────────────────

task.spawn(function()
    -- Stagger the first collections slightly so they don't fire at once on load
    task.wait(5)
    if buffsEnabled()  then runBuffCollection()  end
    task.wait(2)
    if cloverEnabled() then runCloverCollection() end

    while true do
        task.wait(1)
        if not isRunning() then continue end
        if isCollectingPickup then continue end

        local now = tick()

        -- Clover takes priority (less frequent, so check first to avoid clashing)
        if cloverEnabled() and now - lastCloverTime >= CLOVER_INTERVAL then
            -- Yield until eggs are not mid-walk, then go
            local waited = 0
            while isWalking and waited < 10 do task.wait(0.5) waited += 0.5 end
            isWalking = false  -- force-release if stuck
            runCloverCollection()
        elseif buffsEnabled() and now - lastBuffTime >= BUFF_INTERVAL then
            local waited = 0
            while isWalking and waited < 10 do task.wait(0.5) waited += 0.5 end
            isWalking = false
            runBuffCollection()
        end
    end
end)

-- ─────────────────────────────────────────────────────────────────────
-- EGG WALKING
-- ─────────────────────────────────────────────────────────────────────

local lastRescan = 0
local function rescanWorkspace()
    if tick() - lastRescan < 1 then return end
    lastRescan = tick()
    for _, v in ipairs(workspace:GetChildren()) do checkEgg(v) end
end

local function walkToEgg(targetInstance, eggColor)
    local char = getChar()
    local hum  = getHum(char)
    local root = getRoot(char)
    if not hum or not root then return "fail" end

    for attempt = 1, MAX_PATH_ATTEMPTS do
        if not farmEnabled() then return "stopped" end

        local targetPos = resolvePos(targetInstance)
        if not targetPos then return "done" end

        local waypoints = nil
        for _, extraRadius in ipairs({0,2,4,6,8}) do
            local candidate = computeSafePath(root.Position, targetPos, extraRadius)
            if candidate then
                local wps = candidate:GetWaypoints()
                if not pathHasGap(wps) then
                    waypoints = wps
                    if extraRadius > 0 then warn("[EggBot] Gap-free path found with radius +" .. extraRadius) end
                    break
                end
            end
        end

        if not waypoints then
            warn("[EggBot] No gap-free path on attempt " .. attempt)
            task.wait(0.2) continue
        end

        local pathFolder, cleanup = makePathFolder(waypoints, eggColor)
        local pathBroken = false

        for i, wp in ipairs(waypoints) do
            -- Stop mid-path if a pickup run has been triggered
            if not farmEnabled() or not isAlive(targetInstance) then
                pathBroken = true break
            end
            local prevPos = (i > 1) and waypoints[i-1].Position or root.Position
            if wp.Action == Enum.PathWaypointAction.Jump then doJump(hum) end
            local stepResult = stepToWaypoint(hum, root, wp, prevPos)
            if stepResult == "stuck_reset" or stepResult == "gaptoowide"
                or stepResult == "gapfail" or stepResult ~= "reached"
            then
                pathBroken = true break
            end
        end

        cleanup()
        if not farmEnabled() then return "stopped" end
        if pathBroken then task.wait(0.1) continue end

        local collected = false
        if isAlive(targetInstance) then
            for _, v in ipairs(targetInstance:GetDescendants()) do
                if v:IsA("ProximityPrompt") then
                    task.wait(0.5)
                    fireproximityprompt(v)
                    collected = true
                end
            end
        end
        task.wait(0.1)

        if collected then
            local eggName = targetInstance.Name
            local points  = EGG_POINTS[eggName]
            if points then
                totalPoints        += points
                shared.totalPoints  = totalPoints
                saveStats()
                warn("[EggBot] Collected " .. eggName .. " +" .. points .. " pts (total: " .. totalPoints .. ")")
            end
            rescanWorkspace()
        end

        return "done"
    end
    return "fail"
end

-- ─────────────────────────────────────────────────────────────────────
-- QUEUE
-- ─────────────────────────────────────────────────────────────────────

local function pruneQueue()
    local alive = {}
    for _, e in ipairs(eggQueue) do
        if isAlive(e.target) then table.insert(alive, e) else queuedIds[e.id] = nil end
    end
    eggQueue = alive
end

local function releaseWalking() isWalking = false end

function processQueue()
    if not farmEnabled() or isWalking or #eggQueue == 0 then return end
    isWalking = true
    task.spawn(function()
        local hardTimer = task.delay(WALK_HARD_TIMEOUT, function() releaseWalking() end)
        pruneQueue()
        local data = table.remove(eggQueue, 1)
        if data and queuedIds[data.id] then
            queuedIds[data.id] = nil
            if isAlive(data.target) and farmEnabled() then
                respawnAndWait()
                local result = walkToEgg(data.target, data.color)
                if result == "fail" then
                    failCounts[data.id] = (failCounts[data.id] or 0) + 1
                    if failCounts[data.id] >= 3 then
                        warn("[EggBot] Auto-blacklisting " .. data.id)
                        BLACKLIST[data.target.Name] = true
                    end
                end
            end
        end
        task.cancel(hardTimer)
        releaseWalking()
        if farmEnabled() then task.wait(QUEUE_COOLDOWN) processQueue() end
    end)
end

function checkEgg(v)
    task.spawn(function()
        if not v or not (v:IsA("Model") or v:IsA("BasePart")) then return end
        task.wait(0.1)
        if not isAlive(v) then return end
        local name = v.Name
        if BLACKLIST[name] then return end
        local uid = name .. tostring(v)
        if queuedIds[uid] then return end

        local eggNum     = tonumber(string.match(name, "egg_(%d+)$"))
        local isPriority = PRIORITY_SET[name] == true
        local isPotion   = string.find(name, "potion", 1, true) ~= nil
        local eggColor

        if isPriority then eggColor = PRIORITY_COLOR
        elseif isPotion then eggColor = POTION_COLOR
        elseif eggNum then eggColor = EGG_COLORS[eggNum] or DEFAULT_COLOR
        else return end

        local hasPrompt = false
        for _, d in ipairs(v:GetDescendants()) do
            if d:IsA("ProximityPrompt") then hasPrompt = true break end
        end
        if not hasPrompt then return end

        queuedIds[uid] = true
        table.insert(eggQueue, isPriority and 1 or #eggQueue + 1, { target=v, color=eggColor, id=uid })
        if farmEnabled() then processQueue() end
    end)
end

player.CharacterAdded:Connect(function()
    task.wait(1)
    stuckCheckCount    = 0
    isWalking          = false
    isCollectingPickup = false
    if isRunning() then processQueue() end
end)

