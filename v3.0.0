makeSectionLabel("Features")

makeToggleRow("Farm Eggs", Features.farmEggs, function()
    Features.farmEggs = not Features.farmEggs
    if Features.farmEggs then processQueue() end
    return Features.farmEggs
end)

makeToggleRow("Collect Clovers", Features.collectClover, function()
    Features.collectClover = not Features.collectClover
    Config.COLLECT_CLOVERS = Features.collectClover
