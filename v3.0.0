-- ── Settings UI builders ─────────────────────────────────────────────
local spOrder = 0
local function spNextOrder() spOrder += 1 return spOrder end

local function spSectionLabel(text)
    local f = Instance.new("Frame", spScroll)
    f.Size             = UDim2.new(1, 0, 0, 28)
    f.BackgroundTransparency = 1
    f.LayoutOrder      = spNextOrder()
    f.ZIndex           = 28
    newLabel(f, {
        text  = text,
        font  = Enum.Font.GothamBold,
        size  = 11,
        color = C.accent,
        size2 = UDim2.new(1, 0, 1, 0),
        z     = 29,
    })
end

-- Toggle card
local function spToggle(label, configKey)
    local card = Instance.new("Frame", spScroll)
    card.Size             = UDim2.new(1, 0, 0, 40)
    card.BackgroundColor3 = C.bg2
    card.BorderSizePixel  = 0
    card.LayoutOrder      = spNextOrder()
    card.ZIndex           = 28
    corner(card, 8)

    newLabel(card, {
        text  = label,
        size  = 12,
        color = C.text0,
        size2 = UDim2.new(1, -68, 1, 0),
        pos   = UDim2.new(0, 14, 0, 0),
        z     = 29,
    })

    local track = Instance.new("Frame", card)
    track.Size             = UDim2.new(0, 38, 0, 20)
    track.Position         = UDim2.new(1, -50, 0.5, -10)
    track.BackgroundColor3 = Config[configKey] and C.accent or C.bg3
    track.BorderSizePixel  = 0
    track.ZIndex           = 29
    corner(track, 10)

    local knob = Instance.new("Frame", track)
    knob.Size             = UDim2.new(0, 16, 0, 16)
    knob.Position         = Config[configKey] and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.BorderSizePixel  = 0
    knob.ZIndex           = 30
    corner(knob, 8)

    local hit = Instance.new("TextButton", card)
    hit.Size             = UDim2.new(1, 0, 1, 0)
    hit.BackgroundTransparency = 1
    hit.Text             = ""
    hit.ZIndex           = 31
    hit.AutoButtonColor  = false

    local ti = TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    hit.MouseButton1Click:Connect(function()
        Config[configKey] = not Config[configKey]
        saveConfig()
        local on = Config[configKey]
        TweenService:Create(track, ti, { BackgroundColor3 = on and C.accent or C.bg3 }):Play()
        TweenService:Create(knob,  ti, { Position = on and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8) }):Play()
    end)
end

-- Webhook / text input card
local function spInput(label, configKey, placeholder)
    local card = Instance.new("Frame", spScroll)
    card.Size             = UDim2.new(1, 0, 0, 58)
    card.BackgroundColor3 = C.bg2
    card.BorderSizePixel  = 0
    card.LayoutOrder      = spNextOrder()
    card.ZIndex           = 28
    corner(card, 8)

    newLabel(card, {
        text  = label,
        size  = 10,
        font  = Enum.Font.GothamBold,
        color = C.text2,
        size2 = UDim2.new(1, -28, 0, 18),
        pos   = UDim2.new(0, 12, 0, 4),
        z     = 29,
    })

    -- filled dot indicator
    local dot = Instance.new("Frame", card)
    dot.Size             = UDim2.new(0, 7, 0, 7)
    dot.Position         = UDim2.new(1, -14, 0, 10)
    local hasVal         = Config[configKey] and Config[configKey] ~= ""
    dot.BackgroundColor3 = hasVal and C.green or C.red
    dot.BorderSizePixel  = 0
    dot.ZIndex           = 29
    corner(dot, 4)

    local inputBg = Instance.new("Frame", card)
    inputBg.Size             = UDim2.new(1, -24, 0, 26)
    inputBg.Position         = UDim2.new(0, 12, 0, 24)
    inputBg.BackgroundColor3 = C.bg0
    inputBg.BorderSizePixel  = 0
    inputBg.ZIndex           = 29
    corner(inputBg, 6)

    local box = Instance.new("TextBox", inputBg)
    box.Size                = UDim2.new(1, 0, 1, 0)
    box.BackgroundTransparency = 1
    box.BorderSizePixel     = 0
    box.Text                = Config[configKey] or ""
    box.PlaceholderText     = placeholder or "Paste here..."
    box.TextColor3          = C.accent
    box.PlaceholderColor3   = C.text2
    box.TextSize            = 10
    box.Font                = Enum.Font.GothamMedium
    box.TextXAlignment      = Enum.TextXAlignment.Left
    box.ClearTextOnFocus    = false
    box.TextTruncate        = Enum.TextTruncate.AtEnd
    box.ZIndex              = 30
    pad(box, 8, 8, 0, 0)

    box.FocusLost:Connect(function()
        Config[configKey] = box.Text
        saveConfig()
        local filled = box.Text and box.Text ~= ""
        dot.BackgroundColor3 = filled and C.green or C.red
    end)
end

-- Slider card
local function spSlider(label, configKey, minV, maxV)
    local card = Instance.new("Frame", spScroll)
    card.Size             = UDim2.new(1, 0, 0, 40)
    card.BackgroundColor3 = C.bg2
    card.BorderSizePixel  = 0
    card.LayoutOrder      = spNextOrder()
    card.ZIndex           = 28
    corner(card, 8)

    newLabel(card, {
        text  = label,
        size  = 12,
        color = C.text0,
        size2 = UDim2.new(0, 145, 1, 0),
        pos   = UDim2.new(0, 14, 0, 0),
        z     = 29,
    })

    local valLbl = newLabel(card, {
        text  = tostring(Config[configKey]),
        font  = Enum.Font.GothamBold,
        size  = 12,
        color = C.accent,
        size2 = UDim2.new(0, 30, 1, 0),
        pos   = UDim2.new(1, -40, 0, 0),
        xa    = Enum.TextXAlignment.Right,
        z     = 29,
    })

    local trackBg = Instance.new("Frame", card)
    trackBg.Size             = UDim2.new(1, -195, 0, 4)
    trackBg.Position         = UDim2.new(0, 148, 0.5, -2)
    trackBg.BackgroundColor3 = C.bg3
    trackBg.BorderSizePixel  = 0
    trackBg.ZIndex           = 29
    corner(trackBg, 2)

    local initRel = math.clamp((Config[configKey] - minV) / (maxV - minV), 0, 1)

    local fill = Instance.new("Frame", trackBg)
    fill.Size             = UDim2.new(initRel, 0, 1, 0)
    fill.BackgroundColor3 = C.accent
    fill.BorderSizePixel  = 0
    fill.ZIndex           = 30
    corner(fill, 2)

    local knob = Instance.new("Frame", trackBg)
    knob.Size             = UDim2.new(0, 14, 0, 14)
    knob.Position         = UDim2.new(initRel, -7, 0.5, -7)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.BorderSizePixel  = 0
    knob.ZIndex           = 31
    corner(knob, 7)

    local sliding = false
    local function updateSlider(inputX)
        local tPos  = trackBg.AbsolutePosition.X
        local tSize = trackBg.AbsoluteSize.X
        if tSize <= 0 then return end
        local rel   = math.clamp((inputX - tPos) / tSize, 0, 1)
        local value = math.floor(minV + rel * (maxV - minV) + 0.5)
        rel = (value - minV) / (maxV - minV)
        fill.Size     = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -7, 0.5, -7)
        valLbl.Text   = tostring(value)
        Config[configKey] = value
    end

    local hitbox = Instance.new("TextButton", trackBg)
    hitbox.Size             = UDim2.new(1, 14, 0, 28)
    hitbox.Position         = UDim2.new(0, -7, 0.5, -14)
    hitbox.BackgroundTransparency = 1
    hitbox.Text             = ""
    hitbox.ZIndex           = 32
    hitbox.AutoButtonColor  = false

    hitbox.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.Touch then
            sliding = true
            updateSlider(input.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not sliding then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement
           or input.UserInputType == Enum.UserInputType.Touch then
            updateSlider(input.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if sliding and (input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.Touch) then
            sliding = false
            saveConfig()
        end
    end)
end

