-- ─────────────────────────────────────────────────────────────────────
-- UI  (EggBot panel + Settings panel)  — Full Rewrite
-- Drop this in place of the old UI section, from the line:
--   local oldGui = playerGui:FindFirstChild("EggBotUI")
-- down through the end of the file (AUTOSTART section included).
-- All variables defined earlier in the script are still referenced here.
-- ─────────────────────────────────────────────────────────────────────

-- ── Destroy any previous GUI ─────────────────────────────────────────
local oldGui = playerGui:FindFirstChild("EggBotUI")
if oldGui then oldGui:Destroy() end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name           = "EggBotUI"
ScreenGui.ResetOnSpawn   = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.IgnoreGuiInset = false
ScreenGui.Parent         = playerGui

-- ─────────────────────────────────────────────────────────────────────
-- COLOUR / STYLE CONSTANTS
-- ─────────────────────────────────────────────────────────────────────
local C = {
    bg0      = Color3.fromRGB(12, 12, 18),   -- deepest panel bg
    bg1      = Color3.fromRGB(20, 20, 30),   -- header / section bg
    bg2      = Color3.fromRGB(28, 28, 42),   -- row / input bg
    bg3      = Color3.fromRGB(36, 36, 52),   -- hover / subtle
    accent   = Color3.fromRGB(0, 170, 255),  -- blue accent
    accentDk = Color3.fromRGB(0, 110, 180),
    green    = Color3.fromRGB(0, 200, 100),
    red      = Color3.fromRGB(220, 60, 60),
    orange   = Color3.fromRGB(255, 160, 0),
    text0    = Color3.fromRGB(230, 230, 240), -- primary text
    text1    = Color3.fromRGB(160, 160, 185), -- secondary text
    text2    = Color3.fromRGB(90,  90,  115), -- muted / divider text
    divider  = Color3.fromRGB(35,  35,  52),
    rare     = Color3.fromRGB(255, 100, 220),
}

local function corner(parent, r)
    local c = Instance.new("UICorner", parent)
    c.CornerRadius = UDim.new(0, r or 8)
    return c
end
local function stroke(parent, color, thick)
    local s = Instance.new("UIStroke", parent)
    s.Color     = color or C.divider
    s.Thickness = thick or 1
    return s
end
local function pad(parent, l, r, t, b)
    local p = Instance.new("UIPadding", parent)
    p.PaddingLeft   = UDim.new(0, l or 0)
    p.PaddingRight  = UDim.new(0, r or 0)
    p.PaddingTop    = UDim.new(0, t or 0)
    p.PaddingBottom = UDim.new(0, b or 0)
    return p
end
local function newLabel(parent, props)
    local l = Instance.new("TextLabel", parent)
    l.BackgroundTransparency = 1
    l.Font       = props.font or Enum.Font.GothamMedium
    l.TextScaled = false
    l.TextSize   = props.size or 13
    l.TextColor3 = props.color or C.text0
    l.Text       = props.text or ""
    l.TextXAlignment = props.xa or Enum.TextXAlignment.Left
    l.TextYAlignment = props.ya or Enum.TextYAlignment.Center
    l.Size  = props.size2 or UDim2.new(1, 0, 1, 0)
    l.Position = props.pos or UDim2.new(0, 0, 0, 0)
    l.ZIndex = props.z or 11
    l.TextTruncate = Enum.TextTruncate.AtEnd
    return l
end

