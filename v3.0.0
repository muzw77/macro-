local settingsOpen = false
local function openSettings()
    settingsOpen = true
    SettingsOverlay.Visible = true
    SettingsPanel.Size = UDim2.new(0.85, 0, 0, 0)
    TweenService:Create(SettingsPanel, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Size = UDim2.new(0.85, 0, 0.82, 0)}):Play()
end
local function closeSettings()
    settingsOpen = false
    TweenService:Create(SettingsPanel, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
        {Size = UDim2.new(0.85, 0, 0, 0)}):Play()
    task.delay(0.2, function()
        if not settingsOpen then SettingsOverlay.Visible = false end
    end)
end

spCloseBtn.MouseButton1Click:Connect(closeSettings)
SettingsOverlay.MouseButton1Click:Connect(closeSettings)

-- Settings panel drag
local spDragging, spDragStart, spStartPos
spHeader.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        spDragging = true spDragStart = input.Position spStartPos = SettingsPanel.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then spDragging = false end
        end)
    end
end)

-- Stats loop
task.spawn(function()
    while true do
        task.wait(1)
        local elapsed = math.floor(tick() - startTime)
        local pph     = math.floor((totalPoints / math.max(1, elapsed)) * 3600)
        local mins    = math.floor(elapsed / 60)
        local secs    = elapsed % 60

        timeVal.Text   = string.format("%dm %02ds", mins, secs)
        pointsVal.Text = tostring(totalPoints)
        pphVal.Text    = tostring(pph)
        queueVal.Text  = tostring(#eggQueue)
        rareVal.Text   = tostring(#rareEggQueue)

        if isCollectingPickup then
            statusVal.Text = "🍀 Clover run"
        elseif isWalking then
            statusVal.Text = "🥚 Farming"
        else
            statusVal.Text = "Idle"
        end

        local root = getRoot(getChar())
        if currentTarget and isAlive(currentTarget.target) and root then
            local tPos = resolvePos(currentTarget.target)
            targetVal.Text  = currentTarget.target.Name
            targetDist.Text = tPos and (math.floor((root.Position - tPos).Magnitude) .. " studs") or "?"
        else
            targetVal.Text  = "—"
            targetDist.Text = "—"
        end

        webhookVal.Text = Config.WEBHOOK_ENABLED and "ON" or "OFF"

        if #eggQueue == 0 then
            queueListLbl.Text = "No eggs queued"
            queueListLbl.Size = UDim2.new(1, 0, 0, 20)
        else
            local names = {}
            for i = 1, math.min(3, #eggQueue) do
                table.insert(names, eggQueue[i].target.Name)
            end
            if #eggQueue > 3 then table.insert(names, "... +" .. (#eggQueue-3) .. " more") end
            queueListLbl.Text = table.concat(names, "\n")
            queueListLbl.Size = UDim2.new(1, 0, 0, math.min(#eggQueue, 3) * 20 + (#eggQueue > 3 and 20 or 0))
        end
    end
end)

