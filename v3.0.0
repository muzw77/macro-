setRunning(true)
lastMoveTick = tick()

for _, v in ipairs(workspace:GetChildren()) do checkEgg(v) end
workspace.ChildAdded:Connect(checkEgg)
processQueue()

-- Initial buff collection
task.delay(3, function()
    if buffsEnabled() then collectBuffs() end
end)

