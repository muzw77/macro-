-- [PERF] ──────────────────────────────────────────────────────────────
-- PERFORMANCE OPTIMIZATIONS
-- Applied at startup before anything else loads.
-- ─────────────────────────────────────────────────────────────────────

local RunService    = game:GetService("RunService")
local Lighting      = game:GetService("Lighting")
local TweenService  = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

-- [PERF] Disable global shadows to reduce GPU load
pcall(function()
    Lighting.GlobalShadows = false
end)

-- [PERF] Reduce ambient/fog settings for less post-process overhead
pcall(function()
    Lighting.FogEnd   = 100000
    Lighting.FogStart = 100000
end)

-- [PERF] Remove post-processing effects (blur, color correction, bloom, etc.)
pcall(function()
    for _, effect in ipairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") then
            effect.Enabled = false
        end
    end
end)

-- [PERF] Helper: strip visuals from a BasePart (textures, decals, particles)
local function stripPartVisuals(part)
    if not part or not part:IsA("BasePart") then return end
    pcall(function()
        part.CastShadow  = false
        part.ReceiveAge  = false
    end)
    for _, child in ipairs(part:GetChildren()) do
        pcall(function()
            if child:IsA("Texture") or child:IsA("Decal") then
                child.Transparency = 1
            elseif child:IsA("ParticleEmitter") then
                child.Enabled = false
                child.Rate    = 0
            elseif child:IsA("Trail") then
                child.Enabled = false
            elseif child:IsA("Beam") then
                child.Enabled = false
            elseif child:IsA("SelectionBox") then
                child.SurfaceTransparency = 1
                child.LineThickness = 0
            elseif child:IsA("SpecialMesh") then
                child.TextureId = ""
            end
        end)
    end
end

-- [PERF] Helper: strip visuals from a whole Model (walks all descendants)
local function stripModelVisuals(model)
    if not model then return end
    for _, desc in ipairs(model:GetDescendants()) do
        pcall(function()
            if desc:IsA("BasePart") then
                desc.CastShadow = false
                desc.Material   = Enum.Material.SmoothPlastic
            end
            if desc:IsA("Texture") or desc:IsA("Decal") then
                desc.Transparency = 1
            elseif desc:IsA("ParticleEmitter") then
                desc.Enabled = false
                desc.Rate    = 0
            elseif desc:IsA("Trail") then
                desc.Enabled = false
            elseif desc:IsA("Beam") then
                desc.Enabled = false
            elseif desc:IsA("SelectionBox") then
                desc.SurfaceTransparency = 1
                desc.LineThickness = 0
            elseif desc:IsA("SpecialMesh") then
                desc.TextureId = ""
            elseif desc:IsA("Sky") then
                desc:Destroy()
            end
        end)
    end
end

-- [PERF] Sweep existing workspace children on load
task.spawn(function()
    for _, v in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("BasePart") then
                v.CastShadow = false
            end
            if v:IsA("ParticleEmitter") then
                v.Enabled = false
                v.Rate    = 0
            elseif v:IsA("Trail") then
                v.Enabled = false
            elseif v:IsA("Beam") then
                v.Enabled = false
            elseif v:IsA("Texture") or v:IsA("Decal") then
                v.Transparency = 1
            elseif v:IsA("Sky") then
                v:Destroy()
            elseif v:IsA("SpecialMesh") then
                v.TextureId = ""
            end
        end)
    end
end)

-- [PERF] Strip visuals on any new part/model added to workspace
workspace.DescendantAdded:Connect(function(desc)
    task.defer(function()
        pcall(function()
            if desc:IsA("BasePart") then
                desc.CastShadow = false
            end
            if desc:IsA("ParticleEmitter") then
                desc.Enabled = false
                desc.Rate    = 0
            elseif desc:IsA("Trail") then
                desc.Enabled = false
            elseif desc:IsA("Beam") then
                desc.Enabled = false
            elseif desc:IsA("Texture") or desc:IsA("Decal") then
                desc.Transparency = 1
            elseif desc:IsA("Sky") then
                desc:Destroy()
            elseif desc:IsA("SpecialMesh") then
                desc.TextureId = ""
            end
        end)
    end)
end)

-- [PERF] ──────────────────────────────────────────────────────────────
