-- [PERF] Strip visuals from existing workspace descendants
task.spawn(function()
    for _, v in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("BasePart") then v.CastShadow = false end
            if v:IsA("ParticleEmitter") then v.Enabled = false v.Rate = 0
            elseif v:IsA("Trail") then v.Enabled = false
            elseif v:IsA("Beam") then v.Enabled = false
            elseif v:IsA("Texture") or v:IsA("Decal") then v.Transparency = 1
            elseif v:IsA("Sky") then v:Destroy()
            elseif v:IsA("SpecialMesh") then v.TextureId = ""
            end
        end)
    end
end)

-- [PERF] Strip visuals on new descendants
workspace.DescendantAdded:Connect(function(desc)
    task.defer(function()
        pcall(function()
            if desc:IsA("BasePart") then desc.CastShadow = false end
            if desc:IsA("ParticleEmitter") then desc.Enabled = false desc.Rate = 0
            elseif desc:IsA("Trail") then desc.Enabled = false
            elseif desc:IsA("Beam") then desc.Enabled = false
            elseif desc:IsA("Texture") or desc:IsA("Decal") then desc.Transparency = 1
            elseif desc:IsA("Sky") then desc:Destroy()
            elseif desc:IsA("SpecialMesh") then desc.TextureId = ""
            end
        end)
    end)
end)

-- ─────────────────────────────────────────────────────────────────────
-- STAT PERSISTENCE (writefile / shared fallback)
-- ─────────────────────────────────────────────────────────────────────

local STATS_FILE = "eggbot_stats.json"

local function loadStats()
    -- Try readfile first
    local ok, data = pcall(readfile, STATS_FILE)
    if ok and data and data ~= "" then
        local parsed = pcall(function()
            local t = HttpService:JSONDecode(data)
            shared.totalPoints = t.points or 0
            shared.startTime   = shared.startTime or tick() -- don't restore time, just points
        end)
    end
    shared.totalPoints = shared.totalPoints or 0
    shared.startTime   = shared.startTime   or tick()
end

local function saveStats()
    pcall(writefile, STATS_FILE, HttpService:JSONEncode({ points = shared.totalPoints }))
end

loadStats()

local totalPoints = shared.totalPoints
local startTime   = shared.startTime

