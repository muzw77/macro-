local PATH_PARAMS = {
    AgentHeight     = 1.5,
    AgentRadius     = 2,
    AgentCanJump    = true,
    AgentJumpHeight = 25,
    WaypointSpacing = shared.spacing or 2,
}

local REACH_DIST            = 4.5
local WAYPOINT_TIMEOUT      = 2.5
local MAX_PATH_ATTEMPTS     = 5
local WALK_HARD_TIMEOUT     = 90
local QUEUE_COOLDOWN        = 0.2
local GAP_DEPTH_THRESHOLD   = 5
local MAX_JUMPABLE_GAP      = 4
local PARKOUR_JUMP_BOOST    = true
local STUCK_RESET_THRESHOLD = 4
local stuckCheckCount       = 0

-- ── Buff / Clover timing ──────────────────────────────────────────────
-- ObbyBlessing: try every 2 min, max 3 attempts before skipping
-- Clover:       collect every 4 min
local BUFF_INTERVAL         = 120   -- 2 minutes
local BUFF_MAX_ATTEMPTS     = 3
local CLOVER_INTERVAL       = 240   -- 4 minutes
local BUFF_TOUCH_DIST       = 3
local CLOVER_TOUCH_DIST     = 3

local lastBuffTime          = 0
local lastCloverTime        = 0
