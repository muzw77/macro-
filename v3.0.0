local function saveConfig()
    pcall(writefile, CONFIG_FILE, HttpService:JSONEncode(Config))
end

local function loadConfig()
    if readfile and isfile and isfile(CONFIG_FILE) then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile(CONFIG_FILE))
            if decoded then
                for k, v in pairs(decoded) do
                    if Config[k] ~= nil then Config[k] = v end
                end
            end
        end)
    end
end

loadConfig()

-- ─────────────────────────────────────────────────────────────────────
-- STAT PERSISTENCE
-- ─────────────────────────────────────────────────────────────────────

local function loadStats()
    local ok, data = pcall(readfile, STATS_FILE)
    if ok and data and data ~= "" then
        pcall(function()
            local t = HttpService:JSONDecode(data)
            shared.totalPoints = t.points or 0
        end)
    end
    shared.totalPoints = shared.totalPoints or 0
    shared.startTime   = shared.startTime   or tick()
end

local function saveStats()
    pcall(writefile, STATS_FILE, HttpService:JSONEncode({ points = shared.totalPoints }))
end

loadStats()

