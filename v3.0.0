-- Status section
makeSectionLabel("Status")

local botRunning = false

local _, botToggleRefresh = makeToggleRow("Bot Running", botRunning, function()
    botRunning = not botRunning
    setRunning(botRunning)
    if botRunning then
        toggleNPCPrompts(false)
        processQueue()
        warn("[EggBot] ON")
    else
        toggleNPCPrompts(true)
        warn("[EggBot] OFF")
    end
    return botRunning
end)

makeDivider()

