local function updateScrollCanvas()
    SettingsScroll.CanvasSize = UDim2.new(0, 0, 0,
        math.max(LeftList.AbsoluteContentSize.Y, RightList.AbsoluteContentSize.Y) + 24)
end
LeftList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateScrollCanvas)
RightList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateScrollCanvas)

-- Settings widget helpers
local leftRowCount = 0
local rightRowCount = 0

local function nextCol()
    -- Alternate: left gets rows 0,2,4... right gets 1,3,5...
    -- But we just check which column has less height
    local lH = LeftList.AbsoluteContentSize.Y
    local rH = RightList.AbsoluteContentSize.Y
    return lH <= rH and LeftCol or RightCol
end

