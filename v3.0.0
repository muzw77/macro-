    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(0, 170, 255)
    lbl.TextSize = 12
    lbl.Font = Enum.Font.GothamBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 11
    lbl.Parent = g
    local line = Instance.new("Frame", g)
    line.Size = UDim2.new(1, 0, 0, 1)
    line.Position = UDim2.new(0, 0, 1, -1)
    line.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
    line.BorderSizePixel = 0
    line.ZIndex = 11
    line.Parent = g
end

local function makeToggleRow(label, getVal, setVal)
    local col = nextCol()
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -10, 0, 38)
    row.BackgroundColor3 = Color3.fromRGB(22, 22, 32)
    row.BorderSizePixel = 0
    row.ZIndex = 11
    row.Parent = col
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -60, 1, 0)
    lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(190, 190, 210)
    lbl.TextSize = 11
    lbl.Font = Enum.Font.GothamMedium
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 11

    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(0, 38, 0, 20)
    track.Position = UDim2.new(1, -48, 0.5, -10)
    track.BackgroundColor3 = getVal() and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(40, 40, 55)
    track.BorderSizePixel = 0
    track.ZIndex = 12
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = getVal() and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.BorderSizePixel = 0
    knob.ZIndex = 13
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton", track)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.ZIndex = 14

    btn.MouseButton1Click:Connect(function()
        setVal(not getVal())
        local on = getVal()
        local ti = TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        TweenService:Create(track, ti, {BackgroundColor3 = on and Color3.fromRGB(0,170,255) or Color3.fromRGB(40,40,55)}):Play()
        TweenService:Create(knob,  ti, {Position = on and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)}):Play()
    end)
end

local function makeSliderRow(label, minVal, maxVal, getVal, setVal, suffix)
    local col = nextCol()
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -10, 0, 38)
    row.BackgroundColor3 = Color3.fromRGB(22, 22, 32)
    row.BorderSizePixel = 0
    row.ZIndex = 11
    row.Parent = col
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(0, 90, 1, 0)
    lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(190, 190, 210)
    lbl.TextSize = 11
    lbl.Font = Enum.Font.GothamMedium
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 11

    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(1, -155, 0, 4)
    track.Position = UDim2.new(0, 108, 0.5, -2)
    track.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    track.BorderSizePixel = 0
    track.ZIndex = 11
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local valDisplay = Instance.new("TextLabel", row)
    valDisplay.Size = UDim2.new(0, 38, 1, 0)
    valDisplay.Position = UDim2.new(1, -44, 0, 0)
    valDisplay.BackgroundTransparency = 1
    valDisplay.Text = tostring(getVal()) .. (suffix or "")
    valDisplay.TextColor3 = Color3.fromRGB(0, 170, 255)
    valDisplay.TextSize = 12
    valDisplay.Font = Enum.Font.GothamBold
    valDisplay.ZIndex = 11

    local initRel = math.clamp((getVal() - minVal) / (maxVal - minVal), 0, 1)
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(initRel, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    fill.BorderSizePixel = 0
    fill.ZIndex = 11
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new(initRel, -7, 0.5, -7)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    knob.BorderSizePixel = 0
    knob.ZIndex = 12
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local sliding = false
    local function update(inputX)
        local tPos  = track.AbsolutePosition.X
        local tSize = track.AbsoluteSize.X
        local rel   = math.clamp((inputX - tPos) / tSize, 0, 1)
        local value = math.floor(minVal + rel * (maxVal - minVal) + 0.5)
        rel = (value - minVal) / (maxVal - minVal)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -7, 0.5, -7)
        valDisplay.Text = tostring(value) .. (suffix or "")
        setVal(value)
    end

    local hitBtn = Instance.new("TextButton", track)
    hitBtn.Size = UDim2.new(1, 10, 0, 24)
    hitBtn.Position = UDim2.new(0, -5, 0.5, -12)
    hitBtn.BackgroundTransparency = 1
    hitBtn.Text = ""
    hitBtn.ZIndex = 13

    hitBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            sliding = true
            update(inp.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if sliding and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
            update(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            sliding = false
        end
    end)
end

