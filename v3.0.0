RightCol.Size             = UDim2.new(0.5, -20, 1, 0)
RightCol.Position         = UDim2.new(0.5, 0, 0, 0)
RightCol.BackgroundTransparency = 1
local RL = Instance.new("UIListLayout", RightCol)
RL.SortOrder = Enum.SortOrder.LayoutOrder RL.Padding = UDim.new(0,6)

-- alternate cols by order parity
local spOrder = 0
local function nextCol() spOrder += 1 return spOrder % 2 == 1 and LeftCol or RightCol end

local function spSectionLabel(text)
    local col = nextCol()
    local g = Instance.new("Frame", col)
    g.Size             = UDim2.new(1,0,0,24)
    g.BackgroundTransparency = 1 g.ZIndex = 17
    local lbl = Instance.new("TextLabel", g)
    lbl.Size           = UDim2.new(1,0,1,0)
    lbl.BackgroundTransparency = 1
    lbl.Text           = text
    lbl.TextColor3     = Color3.fromRGB(0,170,255)
    lbl.TextSize       = 12 lbl.Font = Enum.Font.GothamBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.ZIndex = 17
    -- mirror to other col for alignment
    local g2 = Instance.new("Frame", col == LeftCol and RightCol or LeftCol)
    g2.Size = UDim2.new(1,0,0,24) g2.BackgroundTransparency = 1 g2.ZIndex = 17
    spOrder += 1
end

local function spToggle(label, configKey)
    local col = nextCol()
    local row = Instance.new("Frame", col)
    row.Size             = UDim2.new(1,-10,0,38)
    row.BackgroundColor3 = Color3.fromRGB(22,22,32)
    row.BorderSizePixel  = 0 row.ZIndex = 17
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1,-60,1,0) lbl.Position = UDim2.new(0,12,0,0)
    lbl.BackgroundTransparency = 1 lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(190,190,210) lbl.TextSize = 11
    lbl.Font = Enum.Font.GothamMedium lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 17
    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(0,38,0,20) track.Position = UDim2.new(1,-48,0.5,-10)
    track.BackgroundColor3 = Config[configKey] and Color3.fromRGB(0,170,255) or Color3.fromRGB(40,40,55)
    track.BorderSizePixel = 0 track.ZIndex = 18
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0,16,0,16)
    knob.Position = Config[configKey] and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
    knob.BackgroundColor3 = Color3.new(1,1,1) knob.BorderSizePixel = 0 knob.ZIndex = 19
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local btn = Instance.new("TextButton", track)
    btn.Size = UDim2.new(1,0,1,0) btn.BackgroundTransparency = 1
    btn.Text = "" btn.ZIndex = 20
    btn.MouseButton1Click:Connect(function()
        Config[configKey] = not Config[configKey]
        saveConfig()
        local on = Config[configKey]
        local ti = TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        TweenService:Create(track, ti, {BackgroundColor3 = on and Color3.fromRGB(0,170,255) or Color3.fromRGB(40,40,55)}):Play()
        TweenService:Create(knob,  ti, {Position        = on and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)}):Play()
    end)
end

local function spWebhookInput(label, configKey, placeholder)
    local col = nextCol()
    local row = Instance.new("Frame", col)
    row.Size             = UDim2.new(1,-10,0,52)
    row.BackgroundColor3 = Color3.fromRGB(22,22,32)
    row.BorderSizePixel  = 0 row.ZIndex = 17
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1,-24,0,18) lbl.Position = UDim2.new(0,12,0,4)
    lbl.BackgroundTransparency = 1 lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(140,140,170) lbl.TextSize = 10
    lbl.Font = Enum.Font.GothamBold lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.ZIndex = 17
    local inputBox = Instance.new("TextBox", row)
    inputBox.Size = UDim2.new(1,-24,0,24) inputBox.Position = UDim2.new(0,12,0,22)
    inputBox.BackgroundColor3 = Color3.fromRGB(12,12,18)
    inputBox.BorderSizePixel = 0
    inputBox.Text = Config[configKey] or ""
    inputBox.PlaceholderText = placeholder or "Paste webhook URL..."
    inputBox.TextColor3 = Color3.fromRGB(100,180,255)
    inputBox.PlaceholderColor3 = Color3.fromRGB(50,50,70)
    inputBox.TextSize = 9 inputBox.Font = Enum.Font.GothamMedium
    inputBox.TextXAlignment = Enum.TextXAlignment.Left
    inputBox.ClearTextOnFocus = false inputBox.ClipsDescendants = true
    inputBox.TextTruncate = Enum.TextTruncate.AtEnd inputBox.ZIndex = 18
    Instance.new("UICorner", inputBox).CornerRadius = UDim.new(0, 5)
    local pad = Instance.new("UIPadding", inputBox)
    pad.PaddingLeft = UDim.new(0, 6) pad.PaddingRight = UDim.new(0, 6)
    local dot = Instance.new("Frame", row)
    dot.Size = UDim2.new(0,7,0,7) dot.Position = UDim2.new(1,-18,0,9)
    dot.BackgroundColor3 = (Config[configKey] ~= nil and Config[configKey] ~= "")
        and Color3.fromRGB(0,200,100) or Color3.fromRGB(200,50,50)
    dot.BorderSizePixel = 0 dot.ZIndex = 18
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
    inputBox.FocusLost:Connect(function()
        Config[configKey] = inputBox.Text
        dot.BackgroundColor3 = (inputBox.Text ~= "" and inputBox.Text ~= nil)
            and Color3.fromRGB(0,200,100) or Color3.fromRGB(200,50,50)
        saveConfig()
    end)
end

local function spSlider(label, configKey, minV, maxV)
    local col = nextCol()
    local row = Instance.new("Frame", col)
    row.Size             = UDim2.new(1,-10,0,38)
    row.BackgroundColor3 = Color3.fromRGB(22,22,32)
    row.BorderSizePixel  = 0 row.ZIndex = 17
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(0,95,1,0) lbl.Position = UDim2.new(0,12,0,0)
    lbl.BackgroundTransparency = 1 lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(190,190,210) lbl.TextSize = 11
    lbl.Font = Enum.Font.GothamMedium lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.ZIndex = 17
    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(1,-155,0,4) track.Position = UDim2.new(0,110,0.5,-2)
    track.BackgroundColor3 = Color3.fromRGB(40,40,55) track.BorderSizePixel = 0 track.ZIndex = 17
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    local valLbl = Instance.new("TextLabel", row)
    valLbl.Size = UDim2.new(0,28,1,0) valLbl.Position = UDim2.new(1,-36,0,0)
    valLbl.BackgroundTransparency = 1 valLbl.Text = tostring(Config[configKey])
    valLbl.TextColor3 = Color3.fromRGB(0,170,255) valLbl.TextSize = 12
    valLbl.Font = Enum.Font.GothamBold valLbl.ZIndex = 17
    local initRel = math.clamp((Config[configKey] - minV) / (maxV - minV), 0, 1)
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(initRel,0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(0,170,255)
    fill.BorderSizePixel = 0 fill.ZIndex = 17
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0,14,0,14) knob.Position = UDim2.new(initRel,-7,0.5,-7)
    knob.BackgroundColor3 = Color3.new(1,1,1) knob.BorderSizePixel = 0 knob.ZIndex = 18
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local sliding = false
    local function updateFromInput(ix)
        local tPos  = track.AbsolutePosition.X
        local tSize = track.AbsoluteSize.X
        local rel   = math.clamp((ix - tPos) / tSize, 0, 1)
        local value = math.floor(minV + rel * (maxV - minV) + 0.5)
        rel = (value - minV) / (maxV - minV)
        fill.Size = UDim2.new(rel,0,1,0)
        knob.Position = UDim2.new(rel,-7,0.5,-7)
        valLbl.Text = tostring(value)
        Config[configKey] = value
    end
    local hit = Instance.new("TextButton", track)
    hit.Size = UDim2.new(1,10,0,24) hit.Position = UDim2.new(0,-5,0.5,-12)
    hit.BackgroundTransparency = 1 hit.Text = "" hit.ZIndex = 19
    hit.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliding = true updateFromInput(input.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateFromInput(input.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and sliding then
            sliding = false saveConfig()
        end
    end)
end

