HUDButton.MouseButton1Click:Connect(function()
    Panel.Visible = not Panel.Visible
end)

-- ─────────────────────────────────────────────────────────────────────
-- LIVE STATS LOOP
-- ─────────────────────────────────────────────────────────────────────

task.spawn(function()
    while true do
        task.wait(1)

        -- Session time
        local elapsed = math.floor(tick() - startTime)
        local mins    = math.floor(elapsed / 60)
        local secs    = elapsed % 60
        timeVal.Text  = string.format("%dm %02ds", mins, secs)

        -- Points
        pointsVal.Text = tostring(totalPoints)

        -- Points / hour
        local pph = math.floor((totalPoints / math.max(1, elapsed)) * 3600)
        pphVal.Text = tostring(pph)

        -- Queue sizes
        queueVal.Text = tostring(#eggQueue)
        rareVal.Text  = tostring(#rareEggQueue)

        -- Bot status label colour coding
        if isCollectingPickup then
            statusVal.Text       = "Clover run"
            statusVal.TextColor3 = C.green
        elseif isWalking then
            statusVal.Text       = "Farming"
            statusVal.TextColor3 = C.accent
        else
            statusVal.Text       = "Idle"
            statusVal.TextColor3 = C.text1
        end

        -- Current target
        local root = getRoot(getChar())
        if currentTarget and isAlive(currentTarget.target) and root then
            local tPos = resolvePos(currentTarget.target)
            targetVal.Text  = currentTarget.target.Name
            targetDist.Text = tPos
                and (math.floor((root.Position - tPos).Magnitude) .. " studs")
                or  "?"
        else
            targetVal.Text  = "—"
            targetDist.Text = "—"
        end

        -- Webhooks
        local wOn = Config.WEBHOOK_ENABLED
        webhookVal.Text       = wOn and "Enabled" or "Disabled"
        webhookVal.TextColor3 = wOn and C.green or C.red

        -- Queue peek
        if #eggQueue == 0 then
            queuePeekLabel.Text = "No eggs queued"
            queuePeekLabel.Size = UDim2.new(1, 0, 0, 20)
        else
            local lines = {}
            for i = 1, math.min(3, #eggQueue) do
                table.insert(lines, eggQueue[i].target.Name)
            end
            if #eggQueue > 3 then
                table.insert(lines, "+ " .. (#eggQueue - 3) .. " more")
            end
            queuePeekLabel.Text = table.concat(lines, "\n")
            local lineCount     = math.min(#eggQueue, 3) + (#eggQueue > 3 and 1 or 0)
            queuePeekLabel.Size = UDim2.new(1, 0, 0, lineCount * 20)
        end
    end
end)

