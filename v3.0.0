-- ─────────────────────────────────────────────────────────────────────
-- BOT SETTINGS (editable via Settings panel)
-- ─────────────────────────────────────────────────────────────────────
shared.spacing = shared.spacing or 2

local BotConfig = {
    WaypointSpacing     = shared.spacing,
    ReachDist           = 4.5,
    WaypointTimeout     = 2.5,
    WalkHardTimeout     = 90,
    GlobalStuckTimeout  = 90,
    DevMode             = false,   -- show path dots
    QueueCooldown       = 0.2,
}

local PATH_PARAMS = {
    AgentHeight     = 1.5,
    AgentRadius     = 2,
    AgentCanJump    = true,
    AgentJumpHeight = 25,
    WaypointSpacing = BotConfig.WaypointSpacing,
}

local REACH_DIST           = BotConfig.ReachDist
local WAYPOINT_TIMEOUT     = BotConfig.WaypointTimeout
local STUCK_VEL_THRESHOLD  = 1.5
local STUCK_CHECK_AFTER    = 0.8
local MAX_PATH_ATTEMPTS    = 5
local WALK_HARD_TIMEOUT    = BotConfig.WalkHardTimeout
local GLOBAL_STUCK_TIMEOUT = BotConfig.GlobalStuckTimeout
local QUEUE_COOLDOWN       = BotConfig.QueueCooldown

local GAP_DEPTH_THRESHOLD  = 5
local MAX_JUMPABLE_GAP     = 4
local PARKOUR_JUMP_BOOST   = true

local STUCK_RESET_THRESHOLD = 4
local stuckCheckCount       = 0

local EGG_POINTS = {
    point_egg_1 = 50,
    point_egg_2 = 100,
    point_egg_3 = 150,
    point_egg_4 = 200,
    point_egg_5 = 300,
    point_egg_6 = 500,
}

local EGG_COLORS = {
    [1] = Color3.fromRGB(255, 255, 255),
    [2] = Color3.fromRGB(0,   255, 0),
    [3] = Color3.fromRGB(0,   170, 255),
    [4] = Color3.fromRGB(170, 0,   255),
    [5] = Color3.fromRGB(255, 170, 0),
    [6] = Color3.fromRGB(255, 0,   0),
}
local JUMP_COLOR     = Color3.fromRGB(255, 100, 0)
local PRIORITY_COLOR = Color3.fromRGB(255, 0,   0)
local POTION_COLOR   = Color3.fromRGB(170, 0,   255)
local DEFAULT_COLOR  = Color3.new(1, 1, 1)
local GAP_COLOR      = Color3.fromRGB(255, 50, 50)

local PRIORITY_SET = {
    andromeda_egg      = true,
    angelic_egg        = true,
    blooming_egg       = true,
    dreamer_egg        = true,
    egg_v2             = true,
    forest_egg         = true,
    hatch_egg          = true,
    royal_egg          = true,
    the_egg_of_the_sky = true,
    point_egg_1        = true,
    point_egg_2        = true,
    point_egg_3        = true,
    point_egg_4        = true,
