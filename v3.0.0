-- Queue list label
local queueListLbl = Instance.new("TextLabel")
queueListLbl.Size              = UDim2.new(1, 0, 0, 20)
queueListLbl.BackgroundTransparency = 1
queueListLbl.TextColor3        = Color3.fromRGB(100,100,100)
queueListLbl.TextScaled        = true
queueListLbl.Font              = Enum.Font.SourceSans
queueListLbl.Text              = "No eggs queued"
queueListLbl.TextXAlignment    = Enum.TextXAlignment.Left
queueListLbl.LayoutOrder       = 15
queueListLbl.ZIndex            = 11
queueListLbl.Parent            = ScrollFrame

-- ── Stats update loop ─────────────────────────────────────────────────

task.spawn(function()
    while true do
        task.wait(1)
        local elapsed = math.floor(tick() - startTime)
        local pph     = math.floor((totalPoints / math.max(1, elapsed)) * 3600)
        local mins    = math.floor(elapsed / 60)
        local secs    = elapsed % 60

        timeVal.Text   = string.format("%dm %02ds", mins, secs)
        pointsVal.Text = tostring(totalPoints)
        queueVal.Text  = tostring(#eggQueue)
        pphVal.Text    = tostring(pph)

        -- Update queue list label with first few egg names
        if #eggQueue == 0 then
            queueListLbl.Text = "No eggs queued"
        else
            local names = {}
            for i = 1, math.min(3, #eggQueue) do
                table.insert(names, eggQueue[i].target.Name)
            end
            if #eggQueue > 3 then table.insert(names, "... +" .. (#eggQueue - 3) .. " more") end
            queueListLbl.Text = table.concat(names, "\n")
        end

        -- Resize queue label to fit content
        queueListLbl.Size = UDim2.new(1, 0, 0, math.max(20, #eggQueue == 0 and 20 or math.min(#eggQueue, 3) * 20 + (#eggQueue > 3 and 20 or 0)))
    end
end)

-- ── Panel toggle ──────────────────────────────────────────────────────

HUDButton.MouseButton1Click:Connect(function()
    Panel.Visible = not Panel.Visible
end)

-- ── Panel dragging (drag via title bar) ──────────────────────────────

local panelDragging, panelDragStart, panelStartPos

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        panelDragging  = true
        panelDragStart = input.Position
        panelStartPos  = Panel.Position
    end
end)

TitleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        panelDragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if panelDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - panelDragStart
        Panel.Position = UDim2.new(
            panelStartPos.X.Scale,
            panelStartPos.X.Offset + delta.X,
            panelStartPos.Y.Scale,
            panelStartPos.Y.Offset + delta.Y
        )
    end
end)

-- ── HUD button dragging ───────────────────────────────────────────────

local hudDragging, hudDragStart, hudStartPos, didDrag

HUDButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        hudDragging  = true
        didDrag      = false
        hudDragStart = input.Position
        hudStartPos  = HUDButton.Position
    end
end)

HUDButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        hudDragging = false
        -- If we dragged, suppress the click toggle
        if didDrag then didDrag = false end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if hudDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - hudDragStart
        if delta.Magnitude > 4 then didDrag = true end
        HUDButton.Position = UDim2.new(
            hudStartPos.X.Scale,
            hudStartPos.X.Offset + delta.X,
            hudStartPos.Y.Scale,
            hudStartPos.Y.Offset + delta.Y
        )
    end
end)

