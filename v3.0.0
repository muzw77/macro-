-- LAUNCH SYSTEM (AUTOEXEC SAFE + SINGLE INSTANCE)

repeat task.wait() until game:IsLoaded()

shared.EggBotRunning = shared.EggBotRunning or false

local function isRunning()
    return shared.EggBotRunning == true
end

local function setRunning(v)
    shared.EggBotRunning = v
end

if isRunning() then
    warn("[EggBot] Previous instance detected, shutting it down...")
    setRunning(false)
    task.wait(0.5)
end

setRunning(true)

if workspace:FindFirstChild("Slope1") then
    task.spawn(function()
        workspace:FindFirstChild("Slope1"):Destroy()
        workspace:FindFirstChild("Anti-Stuck1"):Destroy()
        workspace:FindFirstChild("Anti-Stuck2"):Destroy()
        workspace:FindFirstChild("Anti-Stuck3"):Destroy()
        workspace:FindFirstChild("Anti-Stuck4"):Destroy()
    end)
end

-- [PERF] Helper to make a clean, shadow-free, texture-free bot part
local function makePart(props)
    local p = Instance.new("Part", game.Workspace)
    p.CastShadow   = false
    p.Material     = Enum.Material.SmoothPlastic
    for k, v in pairs(props) do p[k] = v end
    return p
end

