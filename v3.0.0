setRunning(true)
lastMoveTick = tick()
toggleNPCPrompts(false)

for _, v in ipairs(workspace:GetChildren()) do checkEgg(v) end
workspace.ChildAdded:Connect(checkEgg)

pcall(scanForRareEggs)
processQueue()

