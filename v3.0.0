-- Panel drag
local panelDragging, panelDragStart, panelStartPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        panelDragging = true panelDragStart = input.Position panelStartPos = Panel.Position
    end
end)
TitleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then panelDragging = false end
end)

-- HUD drag
local hudDragging, hudDragStart, hudStartPos
HUDButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        hudDragging = true hudDragStart = input.Position hudStartPos = HUDButton.Position
    end
end)
HUDButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then hudDragging = false end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
    if panelDragging then
        local delta = input.Position - panelDragStart
        Panel.Position = UDim2.new(panelStartPos.X.Scale, panelStartPos.X.Offset + delta.X,
            panelStartPos.Y.Scale, panelStartPos.Y.Offset + delta.Y)
    end
    if hudDragging then
        local delta = input.Position - hudDragStart
        HUDButton.Position = UDim2.new(hudStartPos.X.Scale, hudStartPos.X.Offset + delta.X,
            hudStartPos.Y.Scale, hudStartPos.Y.Offset + delta.Y)
    end
    if spDragging and spDragStart and spStartPos then
        local delta = input.Position - spDragStart
        SettingsPanel.Position = UDim2.new(spStartPos.X.Scale, spStartPos.X.Offset + delta.X,
            spStartPos.Y.Scale, spStartPos.Y.Offset + delta.Y)
    end
end)

