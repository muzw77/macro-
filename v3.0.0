-- ── helpers for main panel rows ──────────────────────────────────────
local rowOrder = 0
local function nextOrder() rowOrder += 1 return rowOrder end

local function makeSectionLabel(text)
    local f = Instance.new("Frame", Scroll)
    f.Size             = UDim2.new(1, 0, 0, 26)
    f.BackgroundTransparency = 1
    f.LayoutOrder      = nextOrder()
    f.ZIndex           = 16
    newLabel(f, {
        text  = string.upper(text),
        font  = Enum.Font.GothamBold,
        size  = 10,
        color = C.text2,
        size2 = UDim2.new(1, 0, 1, 0),
        z     = 17,
    })
end

local function makeDivider()
    local d = Instance.new("Frame", Scroll)
    d.Size             = UDim2.new(1, 0, 0, 1)
    d.BackgroundColor3 = C.divider
    d.BorderSizePixel  = 0
    d.LayoutOrder      = nextOrder()
    d.ZIndex           = 16
end

-- Toggle row: returns (row, refreshFn)
local function makeToggleRow(labelText, initState, onToggle)
    local row = Instance.new("Frame", Scroll)
    row.Size             = UDim2.new(1, 0, 0, 36)
    row.BackgroundTransparency = 1
    row.LayoutOrder      = nextOrder()
    row.ZIndex           = 16

    newLabel(row, {
        text  = labelText,
        size  = 13,
        color = C.text0,
        size2 = UDim2.new(1, -58, 1, 0),
        pos   = UDim2.new(0, 0, 0, 0),
        z     = 17,
    })

    local track = Instance.new("Frame", row)
    track.Size             = UDim2.new(0, 40, 0, 22)
    track.Position         = UDim2.new(1, -40, 0.5, -11)
    track.BackgroundColor3 = initState and C.green or C.red
    track.BorderSizePixel  = 0
    track.ZIndex           = 17
    corner(track, 11)

    local knob = Instance.new("Frame", track)
    knob.Size             = UDim2.new(0, 16, 0, 16)
    knob.Position         = initState and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.BorderSizePixel  = 0
    knob.ZIndex           = 18
    corner(knob, 8)

    local hitbox = Instance.new("TextButton", track)
    hitbox.Size             = UDim2.new(1, 0, 1, 0)
    hitbox.BackgroundTransparency = 1
    hitbox.Text             = ""
    hitbox.ZIndex           = 19
    hitbox.AutoButtonColor  = false

    local state = initState
    local ti = TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    local function refresh(s)
        state = s
        TweenService:Create(track, ti, { BackgroundColor3 = s and C.green or C.red }):Play()
        TweenService:Create(knob,  ti, { Position = s and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8) }):Play()
    end

    hitbox.MouseButton1Click:Connect(function()
        local newState = onToggle()
        refresh(newState)
    end)

    return row, refresh
end

-- Stat row: returns the value label
local function makeStatRow(labelText, valueText)
    local row = Instance.new("Frame", Scroll)
    row.Size             = UDim2.new(1, 0, 0, 28)
    row.BackgroundTransparency = 1
    row.LayoutOrder      = nextOrder()
    row.ZIndex           = 16

    newLabel(row, {
        text  = labelText,
        size  = 12,
        color = C.text1,
        size2 = UDim2.new(0.55, 0, 1, 0),
        z     = 17,
    })

    local val = newLabel(row, {
        text  = valueText or "—",
        size  = 12,
        font  = Enum.Font.GothamBold,
        color = C.text0,
        size2 = UDim2.new(0.45, 0, 1, 0),
        pos   = UDim2.new(0.55, 0, 0, 0),
        xa    = Enum.TextXAlignment.Right,
        z     = 17,
    })
    return val
end

