local LeftCol = Instance.new("Frame", spScroll)
LeftCol.Size             = UDim2.new(0.5, -10, 1, 0)
LeftCol.Position         = UDim2.new(0, 10, 0, 0)
LeftCol.BackgroundTransparency = 1
local LL = Instance.new("UIListLayout", LeftCol)
LL.SortOrder = Enum.SortOrder.LayoutOrder LL.Padding = UDim.new(0,6)

