-- ─────────────────────────────────────────────────────────────────────
-- WEBHOOK SYSTEM
-- ─────────────────────────────────────────────────────────────────────

local function sendGenericWebhook(webhookUrl, title, description, color, ping, fields)
    if not Config.WEBHOOK_ENABLED then return end
    if not webhookUrl or webhookUrl == "" then return end

    local finalPing = ping or ""
    if finalPing ~= "" and Config.VIP_SERVER_LINK ~= "" then
        finalPing = finalPing .. "\n\n🔗 **Join server:** " .. Config.VIP_SERVER_LINK
    end

    local data = {
        ["content"] = finalPing,
        ["allowed_mentions"] = { ["parse"] = {"users","roles"} },
        ["embeds"] = {{
            ["title"]       = title,
            ["description"] = description,
            ["color"]       = color,
            ["fields"]      = fields,
            ["footer"]      = { ["text"] = "EggBot v3.3.0" }
        }}
    }

    local req = nil
    if typeof(request)       == "function" then req = request
    elseif typeof(http_request) == "function" then req = http_request
    elseif syn and typeof(syn.request) == "function" then req = syn.request
    elseif http and typeof(http.request) == "function" then req = http.request
    end

    if not req then warn("[Webhook] No HTTP request function found!") return end

    pcall(function()
        req({
            Url     = webhookUrl,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode(data)
        })
    end)
end

local function getPingText()
    if Config.WEBHOOK_PING_ID and Config.WEBHOOK_PING_ID ~= "" then
        local id = string.gsub(Config.WEBHOOK_PING_ID, "[^%d]", "")
        if id ~= "" then return "<@" .. id .. ">" end
    end
    return ""
end

-- Send webhook when an egg is collected
local function sendEggWebhook(eggName)
    local num = tonumber(string.match(eggName, "%d+") or 0)
    local isPotion = string.match(eggName, "potion")
    local pts = EGG_POINTS[eggName]

    task.wait(1.5)

    local curPoints = tostring(totalPoints)
    local titleText  = isPotion and "🧪 Potion Egg Collected!" or "🥚 Egg Collected!"
    local embedColor = isPotion and 10181046 or 14925732
    local fields = {}
    if pts then
        table.insert(fields, {["name"]="💎 Points Gained", ["value"]=tostring(pts), ["inline"]=true})
    end
    table.insert(fields, {["name"]="💰 Total Points", ["value"]=curPoints, ["inline"]=true})

    sendGenericWebhook(Config.WEBHOOK_URL, titleText, "Collected **"..eggName.."**", embedColor, "", fields)
end

-- ─────────────────────────────────────────────────────────────────────
-- WEATHER / BIOME WEBHOOK
-- ─────────────────────────────────────────────────────────────────────

local WEATHER_COLORS = {
    normal=16777215, windy=11393254, snowy=11393254, rainy=3447003,
    sandstorm=15787660, hell=16753920, starfall=3447003, heaven=16777184,
    corruption=8388736, null=8421504, dreamspace=16761035, glitched=3800852,
    cyberspace=11393254, eggland=9502544
}

local lastWeather = ""

local function normalizeBiomeName(text)
    return string.gsub(string.lower(text), "%s+", "")
end

local function isValidBiome(name)
    local lower = string.lower(name)
    if lower == "none" or lower == "tip" or lower == "system" then return false end
    if string.find(lower, "%segg") or lower == "egg" then return false end
    if lower == "normal" then return true end
    local normalized = normalizeBiomeName(name)
    for k in pairs(WEATHER_COLORS) do
        if string.find(normalized, k) then return true end
    end
    return false
end

local function stripRichText(text)
    if not text or typeof(text) ~= "string" then return "" end
    local s = string.gsub(text, "<[^>]+>", "")
    s = string.gsub(s, "^%s+", "") s = string.gsub(s, "%s+$", "")
    return s
end

local function updateWeatherStatus(rawText)
    local text = string.lower(rawText)
    if text == lastWeather or rawText == "" then return end
    lastWeather = text

    local biomeName = text
    local color = WEATHER_COLORS.normal
    local ping  = ""
    local normalized = normalizeBiomeName(rawText)

    if string.find(text, "glitch") then biomeName = "glitched"
    else
        for k, v in pairs(WEATHER_COLORS) do
            if string.find(normalized, k) then biomeName = k color = v break end
        end
    end
    if biomeName == "glitched" then color = WEATHER_COLORS.glitched end
    if biomeName == "dreamspace" or biomeName == "glitched" or biomeName == "cyberspace" then
        ping = getPingText()
    end
    if string.find(biomeName, "none") then return end

    sendGenericWebhook(Config.WEBHOOK_WEATHER, "🌦 Weather Changed!", "Biome: **"..rawText.."**", color, ping)
end

local function checkWeather()
    pcall(function()
        local mi = player.PlayerGui.MainInterface
        for _, obj in ipairs(mi:GetDescendants()) do
            if obj:IsA("TextLabel") then
                local txt = obj.Text
                if not txt or txt == "" or txt == "Label" then continue end
                local lower = string.lower(txt)
                if string.find(lower, "%segg") or lower == "egg" then continue end
                local inner = string.match(txt, "^%[%s*(.-)%s*%]$")
                if inner and isValidBiome(inner) then
                    updateWeatherStatus(txt) break
                elseif (obj.ZIndex == 2 or obj.ZIndex == 3) and isValidBiome(txt) then
                    updateWeatherStatus("[ " .. string.upper(txt) .. " ]") break
                end
            end
        end
    end)
end

-- ─────────────────────────────────────────────────────────────────────
-- MERCHANT DETECTION
-- ─────────────────────────────────────────────────────────────────────

local recentlyNotifiedMerchants = {}

local function checkMerchantMessage(text)
    if not text or typeof(text) ~= "string" then return end
    local cleanText = stripRichText(text)
    if not string.find(cleanText, "[Merchant]", 1, true) then return end
    local lowerText = string.lower(cleanText)
    local merchantName, ping, color = nil, "", 8421504

    if     string.find(lowerText, "jester") then merchantName="Jester" ping=Config.PING_MERCHANT_JESTER and getPingText() or "" color=16711680
    elseif string.find(lowerText, "rin")    then merchantName="Rin"    ping=Config.PING_MERCHANT_RIN    and getPingText() or "" color=3447003
    elseif string.find(lowerText, "mari")   then merchantName="Mari"   ping=Config.PING_MERCHANT_MARI   and getPingText() or "" color=16761035
    end

    local dupeKey = merchantName or cleanText
    local now = tick()
    if recentlyNotifiedMerchants[dupeKey] and (now - recentlyNotifiedMerchants[dupeKey]) < 30 then return end
    recentlyNotifiedMerchants[dupeKey] = now

    if merchantName then
        sendGenericWebhook(Config.WEBHOOK_MERCHANTS,
            "🎪 " .. merchantName .. " has arrived!",
            "**" .. merchantName .. "** appeared!\nMessage: `" .. cleanText .. "`",
            color, ping)
    else
        sendGenericWebhook(Config.WEBHOOK_MERCHANTS, "🎪 Merchant Appeared!",
            "Unknown merchant: `" .. cleanText .. "`", color)
    end
end

-- ─────────────────────────────────────────────────────────────────────
-- AURA ROLL DETECTION
-- ─────────────────────────────────────────────────────────────────────

local recentlyNotifiedAuras = {}

local function checkAuraRollMessage(text)
    if not text or typeof(text) ~= "string" then return end
    if not Config.AURA_NOTIFY_ENABLED then return end
    local cleanText = stripRichText(text)
    if not string.find(cleanText, "HAS FOUND", 1, true) then return end
    if not string.find(cleanText, "CHANCE OF", 1, true) then return end

    local playerInfo, auraName, chanceStr =
        string.match(cleanText, "(.+) HAS FOUND (.+), CHANCE OF 1 IN ([%d,%.]+)")
    if not auraName then
        playerInfo, auraName, chanceStr =
            string.match(cleanText, "(.+) HAS FOUND (.+), CHANCE OF ([%d,%.]+)")
    end
    if not auraName or not chanceStr then return end
    if not string.find(playerInfo, "(@" .. player.Name .. ")", 1, true) then return end

    auraName  = string.gsub(auraName,  "%s*%[.-%]%s*$", "")
    auraName  = string.gsub(auraName,  "%s+$", "")
    local chanceClean = string.gsub(string.gsub(chanceStr, ",", ""), "%.$", "")
    local chanceNumber = tonumber(chanceClean)
    if not chanceNumber or chanceNumber < 1 then return end
    if chanceNumber < math.pow(10, Config.AURA_MIN_SEND) then return end

    local dupeKey = playerInfo .. "_" .. auraName .. "_" .. tostring(chanceNumber)
    if recentlyNotifiedAuras[dupeKey] then return end
    recentlyNotifiedAuras[dupeKey] = true
    task.delay(30, function() recentlyNotifiedAuras[dupeKey] = nil end)

    local function fmt(n)
        if n >= 1e9 then return string.format("%.2fB", n/1e9)
        elseif n >= 1e6 then return string.format("%.2fM", n/1e6)
        elseif n >= 1e3 then return string.format("%.1fK", n/1e3)
        else return tostring(math.floor(n)) end
    end

    local color = 8421504
    if     chanceNumber >= 1e9 then color = 16711680
    elseif chanceNumber >= 1e8 then color = 16753920
    elseif chanceNumber >= 1e7 then color = 16766720
    elseif chanceNumber >= 1e6 then color = 7419530
    elseif chanceNumber >= 1e5 then color = 3447003
    elseif chanceNumber >= 1e4 then color = 3066993
    end

    local ping = chanceNumber >= math.pow(10, Config.AURA_MIN_PING) and getPingText() or ""
    local fields = {
        {["name"]="Aura",   ["value"]="**"..auraName.."**",                  ["inline"]=true},
        {["name"]="Rarity", ["value"]="1 in "..fmt(chanceNumber),            ["inline"]=true},
    }
    sendGenericWebhook(Config.WEBHOOK_AURAS,
        "HAS FOUND " .. auraName .. "!",
        "**" .. playerInfo .. "** obtained **" .. auraName .. "**\nChance: **1 in " .. fmt(chanceNumber) .. "**",
        color, ping, fields)
end

-- ─────────────────────────────────────────────────────────────────────
-- CHAT MONITOR
-- ─────────────────────────────────────────────────────────────────────

local function checkWeatherMessage(text)
    if not text or typeof(text) ~= "string" then return end
    local cleanText = stripRichText(text)
    local biomeMatch = string.match(cleanText, "^%[([%a%s]+)%]%:")
    if biomeMatch then
        biomeMatch = string.gsub(biomeMatch, "%s+$", "")
        if isValidBiome(biomeMatch) then
            updateWeatherStatus("[ " .. string.upper(biomeMatch) .. " ]")
        end
    end
end

local function initChatMonitor()
    pcall(function()
        local TCS = game:GetService("TextChatService")
        if TCS.ChatVersion == Enum.ChatVersion.TextChatService then
            TCS.MessageReceived:Connect(function(msg)
                checkMerchantMessage(msg.Text)
                checkAuraRollMessage(msg.Text)
                checkWeatherMessage(msg.Text)
            end)
        end
    end)
    pcall(function()
        local ev = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
        if ev then
            local onMsg = ev:FindFirstChild("OnNewMessage")
            if onMsg then
                onMsg.OnClientEvent:Connect(function(data)
                    if type(data) == "table" and data.Message then
                        checkMerchantMessage(data.Message)
                        checkAuraRollMessage(data.Message)
                        checkWeatherMessage(data.Message)
                    end
                end)
            end
        end
    end)
    playerGui.DescendantAdded:Connect(function(obj)
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            task.delay(0.2, function()
                pcall(function()
                    checkMerchantMessage(obj.Text)
                    checkAuraRollMessage(obj.Text)
                    checkWeatherMessage(obj.Text)
                end)
            end)
        end
    end)
end

task.spawn(initChatMonitor)

-- ─────────────────────────────────────────────────────────────────────
-- RARE EGG SCANNER
-- ─────────────────────────────────────────────────────────────────────

local detectedRareEggs  = setmetatable({}, {__mode="k"})
local rareEggQueue      = {}
local recentlyNotifiedEggs = {}

local function identifyRareEgg(obj)
    local name = string.lower(obj.Name)
    for _, id in ipairs(RARE_EGG_IDENTIFIERS) do
        if string.find(name, id.namePattern) then return id.displayName end
    end
    local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt")
    if not prompt and obj:IsA("Model") then
        for _, child in ipairs(obj:GetChildren()) do
            prompt = child:FindFirstChildWhichIsA("ProximityPrompt")
            if prompt then break end
        end
    end
    if prompt then
        local a = string.lower(prompt.ActionText or "")
        local o = string.lower(prompt.ObjectText  or "")
        for _, pp in ipairs(RARE_PROMPT_PATTERNS) do
            if string.find(a, pp[1]) or string.find(o, pp[1]) then return pp[2] end
        end
    end
    return nil
end

local function buildRareEggEntry(obj, displayName)
    local part = obj:IsA("BasePart") and obj
        or (obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)))
    if not part then return nil end
    return {
        target   = obj,
        part     = part,
        position = part.Position,
        color    = PRIORITY_COLOR,
        id       = displayName .. tostring(obj),
        isRare   = true,
        rareName = displayName,
    }
end

local function onRareEggDetected(obj, spawned)
    if detectedRareEggs[obj] then return end
    if not (obj:IsA("Model") or obj:IsA("BasePart")) then return end
    local rareName = identifyRareEgg(obj)
    if not rareName then return end
    detectedRareEggs[obj] = true

    local notifKey = "explorer_" .. rareName
    if not recentlyNotifiedEggs[notifKey] then
        recentlyNotifiedEggs[notifKey] = true
        local info  = getRareEggInfo(rareName)
        local emoji = info and info.emoji or "✨"
        sendGenericWebhook(
            Config.WEBHOOK_RARE_EGGS,
            emoji .. (spawned and " RARE EGG JUST SPAWNED!" or " RARE EGG FOUND IN MAP!"),
            "Rare egg detected: **" .. rareName .. "**\nNavigating to collect it!",
            getRareEggColor(rareName),
            getPingText(),
            buildRarityFields(rareName)
        )
        task.delay(120, function() recentlyNotifiedEggs[notifKey] = nil end)
    end

    local entry = buildRareEggEntry(obj, rareName)
    if entry then
        if spawned then
            table.insert(rareEggQueue, 1, entry)
        else
            table.insert(rareEggQueue, entry)
        end
    end
end

local function scanForRareEggs()
    for _, obj in ipairs(workspace:GetChildren()) do
        onRareEggDetected(obj, false)
    end
end

workspace.ChildAdded:Connect(function(obj)
    task.delay(0.5, function()
        if obj and obj.Parent then onRareEggDetected(obj, true) end
    end)
end)

-- ─────────────────────────────────────────────────────────────────────
-- CLOVER FINDER (Map-based model scanning)
-- ─────────────────────────────────────────────────────────────────────

local function findClovers()
    local clovers = {}
    local mapFolder = workspace:FindFirstChild("Map")
    if not mapFolder then return clovers end
    for _, model in ipairs(mapFolder:GetChildren()) do
        if not model:IsA("Model") then continue end
        local effectFolder = model:FindFirstChild("effect")
        if not effectFolder then continue end
        if not effectFolder:FindFirstChild("luckyeffect") then continue end
        local part = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart", true)
        if not part then continue end
        if part.Position.Y > 130 then continue end
        if isPositionExcluded(part.Position) then continue end
        local prompt = model:FindFirstChildWhichIsA("ProximityPrompt", true)
        table.insert(clovers, {
            target   = model,
            part     = part,
            position = part.Position,
            color    = Color3.fromRGB(0, 220, 80),
            id       = "clover_" .. tostring(model),
            isClover = true,
        })
    end
    table.sort(clovers, function(a, b)
        local root = getRoot(getChar())
        if not root then return false end
        return (root.Position - a.position).Magnitude < (root.Position - b.position).Magnitude
    end)
    return clovers
end

-- ─────────────────────────────────────────────────────────────────────
-- PROXIMITY PROMPT DISABLER
-- ─────────────────────────────────────────────────────────────────────

local function toggleNPCPrompts(state)
    local routes = {
        {"Map","QuestBoard","Proximity","ProximityPrompt"},
        {"Map","17597ef9-f805-4ff9-9cd4-86652e056ef9","Torso","ProximityPrompt"},
        {"Map","UGCShop","Title","Attachment","ProximityPrompt"},
        {"Boss Portal","Portal","Attachment","ProximityPrompt"},
        {"Map","Miscs","FishShop","NPC","ProximityPrompt"},
        {"Map","Miscs","Rig","HumanoidRootPart","ProximityPrompt"},
        {"Map","Miscs","HoodedFigure","ProximityPrompt"},
        {"Map","SHOP","Jake","ProximityPrompt"},
    }
    for _, route in ipairs(routes) do
        local cur = workspace
        for _, name in ipairs(route) do
            if cur then cur = cur:FindFirstChild(name) end
        end
        if cur and cur:IsA("ProximityPrompt") then cur.Enabled = state end
    end
end

-- ─────────────────────────────────────────────────────────────────────
-- AUTO-USE ITEMS (Strange Controller / Biome Randomizer)
-- ─────────────────────────────────────────────────────────────────────

local lastStrangeControllerUse = 0
local lastBiomeRandomizerUse   = 0

local function smartClickBtn(button)
    if not button then return false end
    pcall(function()
        local pos   = button.AbsolutePosition
        local size  = button.AbsoluteSize
        local inset = GuiService:GetGuiInset()
        local cx = pos.X + size.X / 2
        local cy = pos.Y + size.Y / 2 + inset.Y
        VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true,  game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
    end)
    return true
end

local function isGameInventoryVisible()
    local mi = playerGui:FindFirstChild("MainInterface")
    if not mi then return false end
    local inv = mi:FindFirstChild("Inventory")
    return inv and inv.Visible and inv.AbsolutePosition.X > -500
end

local function toggleGameInventory()
    local mi = playerGui:FindFirstChild("MainInterface")
    if not mi then return false end
    local sb = mi:FindFirstChild("SideButtons")
    if not sb then return false end
    local btns = {}
    for _, child in ipairs(sb:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("ImageButton") then
            table.insert(btns, child)
        end
    end
    table.sort(btns, function(a,b) return a.AbsolutePosition.Y < b.AbsolutePosition.Y end)
    if btns[1] then smartClickBtn(btns[1]) task.wait(0.3) return true end
    return false
end

local function closeGameInventory()
    local mi = playerGui:FindFirstChild("MainInterface")
    if not mi then return end
    for _, desc in ipairs(mi:GetDescendants()) do
        if desc:IsA("ImageLabel") and
           (desc.Image == "http://www.roblox.com/asset/?id=6031094678" or
            desc.Image == "rbxassetid://6031094678") then
            local btn = desc.Parent
            if btn and (btn:IsA("ImageButton") or btn:IsA("TextButton")) then
                smartClickBtn(btn) task.wait(0.3) return
            end
        end
    end
    toggleGameInventory()
end

local function useGameItem(itemName)
    local mi = playerGui:FindFirstChild("MainInterface")
    if not mi then return false, "No MainInterface" end
    local inv = mi:FindFirstChild("Inventory")
    if not inv then return false, "No Inventory" end

    local wasOpen = isGameInventoryVisible()
    if not wasOpen then
        toggleGameInventory() task.wait(0.5)
        if not isGameInventoryVisible() then return false, "Couldn't open inventory" end
    end

    -- Switch to Items tab
    pcall(function()
        local itemsFrame = inv:FindFirstChild("Items")
        if itemsFrame then
            local tab = itemsFrame:FindFirstChild("ItemsTab")
            if tab then smartClickBtn(tab) task.wait(0.3) end
        end
    end)

    -- Click quick-category tool filter
    pcall(function()
        local qc = inv:FindFirstChild("QuickCategory")
        if qc then
            for _, child in ipairs(qc:GetChildren()) do
                if child:IsA("ImageButton") then
                    for _, desc in ipairs(child:GetDescendants()) do
                        if desc:IsA("ImageLabel") and desc.Image == "rbxassetid://100436585165147" then
                            smartClickBtn(child) task.wait(0.4) break
                        end
                    end
                end
            end
        end
    end)

    local gridFrame = nil
    pcall(function() gridFrame = inv.Items.ItemGrid.ItemGridScrollingFrame end)
    if not gridFrame then
        for _, desc in ipairs(inv:GetDescendants()) do
            if desc:IsA("ScrollingFrame") and desc.Name:find("Grid") then
                gridFrame = desc break
            end
        end
    end
    if not gridFrame then
        if not wasOpen then closeGameInventory() end
        return false, "Grid not found"
    end

    local itemFrame = gridFrame:FindFirstChild("Item\n" .. itemName)
        or gridFrame:FindFirstChild(itemName)
    if not itemFrame then
        for _, child in ipairs(gridFrame:GetChildren()) do
            if child.Name:find(itemName) then itemFrame = child break end
        end
    end
    if not itemFrame then
        if not wasOpen then closeGameInventory() end
        return false, "Item '" .. itemName .. "' not found"
    end

    local itemBtn = itemFrame:FindFirstChild("Button")
        or itemFrame:FindFirstChildWhichIsA("TextButton")
        or itemFrame:FindFirstChildWhichIsA("ImageButton")
    if not itemBtn and (itemFrame:IsA("TextButton") or itemFrame:IsA("ImageButton")) then
        itemBtn = itemFrame
    end
    if not itemBtn then
        if not wasOpen then closeGameInventory() end
        return false, "No button in item frame"
    end

    smartClickBtn(itemBtn) task.wait(0.4)

    local useBtn = nil
    pcall(function() useBtn = inv.Index.ItemIndex.UseHolder.UseButton end)
    if not useBtn then
        for _, desc in ipairs(inv:GetDescendants()) do
            if (desc.Name == "UseButton" or desc.Name == "Use") and
               (desc:IsA("TextButton") or desc:IsA("ImageButton")) then
                useBtn = desc break
            end
        end
    end
    if not useBtn or not useBtn.Visible then
        if not wasOpen then closeGameInventory() end
        return false, "Use button hidden"
    end

    smartClickBtn(useBtn) task.wait(0.3)
    if not wasOpen then closeGameInventory() end
    return true, "Used " .. itemName
end

local function tryAutoUseItems()
    local now      = tick()
    local interval = Config.ITEM_USE_INTERVAL * 60

    if Config.AUTO_USE_STRANGE_CONTROLLER then
        if (now - lastStrangeControllerUse) >= interval then
            local ok, msg = useGameItem("Strange Controller")
            if ok then
                lastStrangeControllerUse = now
                warn("[AutoItem] Strange Controller used")
            else
                warn("[AutoItem] Strange Controller failed: " .. tostring(msg))
            end
            task.wait(0.5)
        end
    end

    if Config.AUTO_USE_BIOME_RANDOMIZER then
        local should = false
        if Config.AUTO_USE_STRANGE_CONTROLLER then
            if lastStrangeControllerUse > 0
               and lastBiomeRandomizerUse < lastStrangeControllerUse
               and (now - lastStrangeControllerUse) >= 300 then
                should = true
            end
        else
            if (now - lastBiomeRandomizerUse) >= interval then should = true end
        end
        if should then
            local ok, msg = useGameItem("Biome Randomizer")
            if ok then
                lastBiomeRandomizerUse = now
                warn("[AutoItem] Biome Randomizer used")
            else
                warn("[AutoItem] Biome Randomizer failed: " .. tostring(msg))
            end
            task.wait(0.5)
        end
    end
end

-- ─────────────────────────────────────────────────────────────────────
-- STATE
-- ─────────────────────────────────────────────────────────────────────

local isWalking         = false
local eggQueue          = {}
local queuedIds         = {}
local lastMoveTick      = tick()
local currentTarget     = nil
local interruptWalk     = false
local isCollectingPickup = false

local function farmEnabled()  return isRunning() and Features.farmEggs and not isCollectingPickup end
local function cloverEnabled() return isRunning() and Features.collectClover end

-- ─────────────────────────────────────────────────────────────────────
-- HELPERS
-- ─────────────────────────────────────────────────────────────────────

local function isAlive(inst) return inst ~= nil and inst.Parent ~= nil end
local function safeGet(fn) local ok,v = pcall(fn) return ok and v or nil end
local function getChar()  return player.Character end
local function getHum(c)  return c and c:FindFirstChildOfClass("Humanoid") end
function getRoot(c) return c and c:FindFirstChild("HumanoidRootPart") end

local function resolvePos(inst)
    if not isAlive(inst) then return nil end
    return safeGet(function()
        if inst:IsA("BasePart") then return inst.Position end
        if inst:IsA("Model") then
            if inst.PrimaryPart then return inst.PrimaryPart.Position end
            local bp = inst:FindFirstChildWhichIsA("BasePart", true)
            return bp and bp.Position
        end
    end)
end

-- Check if egg has already been collected (transparent = collected)
local function isEggCollected(inst)
    if not inst or not inst.Parent then return true end
    local nameLower = string.lower(inst.Name)
    local isClover  = string.find(nameLower, "clover") ~= nil
    if not isClover then
        if inst:IsA("MeshPart") or inst:IsA("BasePart") then
            if inst.Transparency and inst.Transparency > 0.9 then return true end
        end
        local prompt = inst:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt and not prompt.Enabled then return true end
        if not prompt and inst:IsA("Model") and string.find(nameLower, "egg") then return true end
        for _, desc in ipairs(inst:GetDescendants()) do
            if (desc:IsA("MeshPart") or desc:IsA("SpecialMesh") or desc:IsA("BasePart"))
               and desc.Name ~= "Hitbox" and desc.Name ~= "HumanoidRootPart" then
                if desc.Transparency and desc.Transparency > 0.9 then return true end
            end
        end
    end
    return false
end

-- ─────────────────────────────────────────────────────────────────────
-- SMART SORTING
-- ─────────────────────────────────────────────────────────────────────

local MAX_RARITY_REF = 1500
local MAX_DIST_REF   = 500

local function eggScore(entry, fromPos)
    if not isAlive(entry.target) then return -math.huge end
    local pos = resolvePos(entry.target)
    if not pos then return -math.huge end
    local dist      = (fromPos - pos).Magnitude
    local rarity    = rarityScoreForName(entry.target.Name)
    local rarityNorm = math.min(rarity / MAX_RARITY_REF, 1)
    local distNorm   = 1 - math.min(dist / MAX_DIST_REF, 1)
    return rarityNorm * 0.5 + distNorm * 0.5
end

local function smartSortQueue()
    if not Features.smartSort then return end
    local root = getRoot(getChar())
    if not root then return end
    local fromPos = root.Position
    table.sort(eggQueue, function(a, b)
        return eggScore(a, fromPos) > eggScore(b, fromPos)
    end)
end

local lastSortTime = 0
local function maybeSortQueue()
    if tick() - lastSortTime < SORT_INTERVAL then return end
    lastSortTime = tick()
    smartSortQueue()
end

-- ─────────────────────────────────────────────────────────────────────
-- GAP DETECTION
-- ─────────────────────────────────────────────────────────────────────

local function isGapBelow(position)
    local rayDir = Vector3.new(0, -(GAP_DEPTH_THRESHOLD + 0.5), 0)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local char = getChar()
    if char then params.FilterDescendantsInstances = {char} end
    local offsets = {
        Vector3.new(0,0.5,0), Vector3.new(0.4,0.5,0), Vector3.new(-0.4,0.5,0),
        Vector3.new(0,0.5,0.4), Vector3.new(0,0.5,-0.4),
    }
    for _, offset in ipairs(offsets) do
        if workspace:Raycast(position + offset, rayDir, params) then return false end
    end
    return true
end

local function getGapInfo(fromPos, toPos)
    local horizontalDist = Vector3.new(toPos.X-fromPos.X, 0, toPos.Z-fromPos.Z).Magnitude
    local midPos = (fromPos + toPos) / 2
    if not isGapBelow(toPos) and not isGapBelow(midPos) then return nil end
    if horizontalDist <= MAX_JUMPABLE_GAP then return horizontalDist end
    return false
end

-- ─────────────────────────────────────────────────────────────────────
-- PATH VISUALS
-- ─────────────────────────────────────────────────────────────────────

local function makePathFolder(waypoints, color)
    local folder = Instance.new("Folder")
    folder.Name  = "ActivePath"
    pcall(function()
        for i, wp in ipairs(waypoints) do
            local p = Instance.new("Part")
            p.Shape        = Enum.PartType.Ball
            p.Size         = Vector3.new(0.6,0.6,0.6)
            p.Position     = wp.Position
            p.Anchored     = true
            p.CanCollide   = false
            p.CastShadow   = false
            p.Transparency = shared.dev and 0 or 1
            p.Material     = Enum.Material.SmoothPlastic
            local prevPos  = (i > 1) and waypoints[i-1].Position or wp.Position
            local gapInfo  = getGapInfo(prevPos, wp.Position)
            if gapInfo then p.Color = GAP_COLOR
            elseif wp.Action == Enum.PathWaypointAction.Jump then p.Color = JUMP_COLOR
            else p.Color = color end
            p.Parent = folder
        end
    end)
    folder.Parent = workspace
    local function cleanup()
        task.spawn(function() pcall(function() if folder.Parent then folder:Destroy() end end) end)
    end
    return folder, cleanup
end

-- ─────────────────────────────────────────────────────────────────────
-- MOVEMENT PRIMITIVES
-- ─────────────────────────────────────────────────────────────────────

local function doJump(hum)
    if hum
        and hum:GetState() ~= Enum.HumanoidStateType.Jumping
        and hum:GetState() ~= Enum.HumanoidStateType.Freefall
    then
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end

local function doGapJump(hum, root, targetPos)
    if not hum or not root then return false end
    local dir = (Vector3.new(targetPos.X, root.Position.Y, targetPos.Z) - root.Position).Unit
    if PARKOUR_JUMP_BOOST then
        hum:MoveTo(root.Position + dir * 1.5)
        task.wait(0.08)
    end
    doJump(hum)
    hum:MoveTo(targetPos)
    local t0 = tick()
    while tick() - t0 < 2.5 do
        task.wait()
        local state = hum:GetState()
        if state ~= Enum.HumanoidStateType.Jumping and state ~= Enum.HumanoidStateType.Freefall then return true end
        hum:MoveTo(targetPos)
    end
    return false
end

local function respawnAndWait()
    local humanoid = getHum(getChar())
    if humanoid then humanoid.Health = 0 end
    task.wait(0.5)
    local t0 = tick()
    while tick() - t0 < 10 do
        local c = getChar()
        local hum = getHum(c)
        local root = getRoot(c)
        if c and hum and root and hum.Health > 0 then break end
        task.wait(0.2)
    end
    task.wait(0.3)
end

local function findLadderNear(root)
    local nearby = workspace:GetPartBoundsInBox(CFrame.new(root.Position), Vector3.new(4,6,4))
    for _, part in ipairs(nearby) do
        if part:IsA("BasePart") and not part:IsA("TrussPart") and string.find(part.Name:lower(), "ladder") then
            return part
        end
    end
    return nil
end

local function climbLadder(hum, root, ladder)
    local topY   = ladder.Position.Y + ladder.Size.Y / 2 + 3
    local topPos = Vector3.new(ladder.Position.X, topY, ladder.Position.Z)
    hum:MoveTo(Vector3.new(ladder.Position.X, root.Position.Y, ladder.Position.Z))
    task.wait(0.3)
    local t0 = tick()
    local lastY, stuckT = root.Position.Y, tick()
    while tick() - t0 < 10 do
        task.wait(0.1)
        if root.Position.Y >= topY - 1.5 then return true end
        hum:MoveTo(topPos)
        if root.Position.Y > lastY + 0.1 then
            lastY = root.Position.Y stuckT = tick()
        elseif tick() - stuckT > 2 then
            return false
        end
    end
    return false
end

local function pathHasGap(waypoints)
    for i = 2, #waypoints do
        if getGapInfo(waypoints[i-1].Position, waypoints[i].Position) ~= nil then return true end
    end
    return false
end

local function computeSafePath(fromPos, toPos, extraRadius)
    local params = {
        AgentHeight     = PATH_PARAMS.AgentHeight,
        AgentRadius     = PATH_PARAMS.AgentRadius + (extraRadius or 0),
        AgentCanJump    = PATH_PARAMS.AgentCanJump,
        AgentJumpHeight = PATH_PARAMS.AgentJumpHeight,
        WaypointSpacing = PATH_PARAMS.WaypointSpacing,
    }
    local path = PathfindingService:CreatePath(params)
    local ok = pcall(function() path:ComputeAsync(fromPos, toPos) end)
    if not ok or path.Status ~= Enum.PathStatus.Success then return nil end
    return path
end

-- ─────────────────────────────────────────────────────────────────────
-- STEP TO WAYPOINT
-- ─────────────────────────────────────────────────────────────────────

local function stepToWaypoint(hum, root, wp, prevPos)
    if not hum or not root then return "fail" end
    local fromPos = prevPos or root.Position
    local gapInfo = getGapInfo(fromPos, wp.Position)
    if gapInfo == false then return "gaptoowide"
    elseif gapInfo then
        return doGapJump(hum, root, wp.Position) and "reached" or "gapfail"
    end

    hum:MoveTo(wp.Position)
    local result, startT = nil, tick()
    local lastPos, lastPosTime = root.Position, tick()
    local PROGRESS_CHECK_INTERVAL, MIN_PROGRESS = 0.6, 0.8

    local moveConn = hum.MoveToFinished:Connect(function(reached)
        if result == nil then result = reached and "reached" or "timeout" end
    end)

    while result == nil do
        task.wait()
        if not isRunning() or interruptWalk then result = "interrupted" break end
        if tick() - startT > WAYPOINT_TIMEOUT then result = "timeout" break end
        if (root.Position - wp.Position).Magnitude < REACH_DIST then
            result = "reached" lastMoveTick = tick() stuckCheckCount = 0 break
        end
        local now = tick()
        if now - lastPosTime > PROGRESS_CHECK_INTERVAL then
            local moved = (root.Position - lastPos).Magnitude
            if moved < MIN_PROGRESS then
                stuckCheckCount += 1
                warn("[EggBot] Stuck check " .. stuckCheckCount .. "/" .. STUCK_RESET_THRESHOLD)
                if stuckCheckCount >= STUCK_RESET_THRESHOLD then
                    stuckCheckCount = 0
                    moveConn:Disconnect()
                    respawnAndWait()
                    return "stuck_reset"
                end
                local ladder = findLadderNear(root)
                if ladder then
                    moveConn:Disconnect()
                    result = climbLadder(hum, root, ladder) and "reached" or "timeout"
                    break
                end
                local surpriseGap = getGapInfo(root.Position, root.Position + (wp.Position - root.Position).Unit * 3)
                if surpriseGap and surpriseGap ~= false then
                    if doGapJump(hum, root, wp.Position) then stuckCheckCount = 0 result = "reached" break end
                else
                    local awayDir = (root.Position - wp.Position).Unit
                    hum:MoveTo(root.Position + Vector3.new(awayDir.X*3, 0, awayDir.Z*3))
                    task.wait(0.4)
                    doJump(hum) task.wait(0.05)
                    hum:MoveTo(wp.Position)
                end
            else
                stuckCheckCount = 0
            end
            lastPos = root.Position lastPosTime = now
        end
    end

    moveConn:Disconnect()
    return result
end

-- ─────────────────────────────────────────────────────────────────────
-- GENERIC WALK-TO  (clovers)
-- ─────────────────────────────────────────────────────────────────────

local function walkToTarget(targetInst, touchDist, label, maxAttempts)
    local char = getChar()
    local hum  = getHum(char)
    local root = getRoot(char)
    if not hum or not root then return false end
    maxAttempts = maxAttempts or 3

    for attempt = 1, maxAttempts do
        if not isRunning() then return false end
        local targetPos = resolvePos(targetInst)
        if not targetPos then warn("[EggBot] " .. label .. " disappeared") return false end

        local path = computeSafePath(root.Position, targetPos, 0)
        if not path then
            warn("[EggBot] " .. label .. " path failed attempt " .. attempt)
            task.wait(0.3) continue
        end

        local waypoints = path:GetWaypoints()
        local broken    = false

        for i, wp in ipairs(waypoints) do
            if not isRunning() then broken = true break end
            local prevPos = (i > 1) and waypoints[i-1].Position or root.Position
            if wp.Action == Enum.PathWaypointAction.Jump then doJump(hum) end
            local stepResult = stepToWaypoint(hum, root, wp, prevPos)
            if stepResult ~= "reached" then broken = true break end
            if (root.Position - targetPos).Magnitude <= touchDist then
                warn("[EggBot] Touched: " .. label) return true
            end
        end

        if not broken then
            local finalPos = resolvePos(targetInst)
            if finalPos and (root.Position - finalPos).Magnitude <= touchDist + 2 then
                warn("[EggBot] Touched (end of path): " .. label) return true
            end
        end
        task.wait(0.3)
    end
    warn("[EggBot] " .. label .. " skipped after " .. maxAttempts .. " attempts")
    return false
end

-- ─────────────────────────────────────────────────────────────────────
-- CLOVER COLLECTION LOOP
-- ─────────────────────────────────────────────────────────────────────

local function runCloverCollection()
    if not cloverEnabled() then return end
    if isCollectingPickup then return end

    local clovers = findClovers()
    if #clovers == 0 then
        warn("[EggBot] No clovers found")
        return
    end

    isCollectingPickup = true
    warn("[EggBot] Starting clover run (pausing eggs)")

    for _, cloverEntry in ipairs(clovers) do
        if not cloverEnabled() or not isRunning() then break end
        local success = walkToTarget(cloverEntry.target, CLOVER_TOUCH_DIST, "Clover", 3)
        if success then
            warn("[EggBot] Clover collected!")
            sendGenericWebhook(Config.WEBHOOK_URL, "🍀 Clover Collected!",
                "Collected a **Clover**", 65280, "", {})
        end
    end

    isCollectingPickup = false
    warn("[EggBot] Clover run done, resuming eggs")
    processQueue()
end

-- Clover scheduler
task.spawn(function()
    task.wait(10)
    while true do
        task.wait(30)
        if not isRunning() or isCollectingPickup then continue end
        if cloverEnabled() and not isWalking then
            runCloverCollection()
        end
    end
end)

-- ─────────────────────────────────────────────────────────────────────
-- AUTO-SWITCH: interrupt for nearby priority eggs
-- ─────────────────────────────────────────────────────────────────────

local function checkShouldInterrupt(newEntry)
    if not Features.autoSwitch then return end
    if not isWalking then return end
    if not PRIORITY_SET[newEntry.target.Name] then return end
    if isCollectingPickup then return end
    local root = getRoot(getChar())
    if not root then return end
    local newPos = resolvePos(newEntry.target)
    if not newPos then return end
    local distToNew = (root.Position - newPos).Magnitude
    if distToNew > INTERRUPT_MAX_DIST then return end
    if currentTarget and PRIORITY_SET[currentTarget.target.Name] then return end
    warn("[EggBot] 🔄 Priority egg nearby (" .. newEntry.target.Name .. ") — interrupting!")
    interruptWalk = true
end

-- ─────────────────────────────────────────────────────────────────────
-- EGG WALKING
-- ─────────────────────────────────────────────────────────────────────

local lastRescan = 0
local function rescanWorkspace()
    if tick() - lastRescan < 1 then return end
    lastRescan = tick()
    for _, v in ipairs(workspace:GetChildren()) do checkEgg(v) end
end

local function walkToEgg(targetInstance, eggColor)
    local char = getChar()
    local hum  = getHum(char)
    local root = getRoot(char)
    if not hum or not root then return "fail" end

    interruptWalk = false

    -- Skip if already collected
    if isEggCollected(targetInstance) then
        warn("[EggBot] Egg already collected, skipping: " .. targetInstance.Name)
        return "done"
    end

    -- Skip if in excluded zone
    local targetPos = resolvePos(targetInstance)
    if targetPos and isPositionExcluded(targetPos) then
        warn("[EggBot] Egg in excluded zone, skipping: " .. targetInstance.Name)
        return "done"
    end

    for attempt = 1, MAX_PATH_ATTEMPTS do
        if not farmEnabled() then return "stopped" end

        maybeSortQueue()

        targetPos = resolvePos(targetInstance)
        if not targetPos then return "done" end

        if isEggCollected(targetInstance) then return "done" end

        local waypoints = nil
        for _, extraRadius in ipairs({0,2,4,6,8}) do
            local candidate = computeSafePath(root.Position, targetPos, extraRadius)
            if candidate then
                local wps = candidate:GetWaypoints()
                if not pathHasGap(wps) then
                    waypoints = wps
                    if extraRadius > 0 then warn("[EggBot] Gap-free path radius +" .. extraRadius) end
                    break
                end
            end
        end

        if not waypoints then
            warn("[EggBot] No gap-free path attempt " .. attempt)
            task.wait(0.2) continue
        end

        local pathFolder, cleanup = makePathFolder(waypoints, eggColor)
        local pathBroken = false

        for i, wp in ipairs(waypoints) do
            if not farmEnabled() or not isAlive(targetInstance) then
                pathBroken = true break
            end
            if interruptWalk then
                warn("[EggBot] Path interrupted for priority egg")
                pathBroken = true break
            end
            if isEggCollected(targetInstance) then
                pathBroken = true break
            end

            local prevPos = (i > 1) and waypoints[i-1].Position or root.Position
            if wp.Action == Enum.PathWaypointAction.Jump then doJump(hum) end
            local stepResult = stepToWaypoint(hum, root, wp, prevPos)

            if stepResult == "interrupted" then
                pathBroken = true break
            elseif stepResult == "stuck_reset" or stepResult == "gaptoowide"
                or stepResult == "gapfail" or stepResult ~= "reached"
            then
                pathBroken = true break
            end
        end

        cleanup()
        if not farmEnabled() then return "stopped" end
        if interruptWalk then interruptWalk = false return "interrupted" end
        if pathBroken then task.wait(0.1) continue end

        local collected = false
        if isAlive(targetInstance) and not isEggCollected(targetInstance) then
            for _, v in ipairs(targetInstance:GetDescendants()) do
                if v:IsA("ProximityPrompt") then
                    task.wait(0.5)
                    fireproximityprompt(v)
                    collected = true
                end
            end
        end
        task.wait(0.1)

        if collected then
            local eggName = targetInstance.Name
            local points  = EGG_POINTS[eggName]
            if points then
                totalPoints        += points
                shared.totalPoints  = totalPoints
                saveStats()
                warn("[EggBot] Collected " .. eggName .. " +" .. points .. " pts (total: " .. totalPoints .. ")")
            end
            task.spawn(function() sendEggWebhook(eggName) end)
            rescanWorkspace()
        end

        return "done"
    end

    sendGenericWebhook(Config.WEBHOOK_URL, "⚠️ Pathfinding Failed",
        "Failed to collect **" .. targetInstance.Name .. "**", 16711680, "")
    return "fail"
end

-- ─────────────────────────────────────────────────────────────────────
-- RARE EGG WALKING (highest priority, bypasses normal queue)
-- ─────────────────────────────────────────────────────────────────────

local function processRareEggQueue()
    while #rareEggQueue > 0 and farmEnabled() do
        local entry = table.remove(rareEggQueue, 1)
        if entry.part and entry.part.Parent then
            warn("[EggBot] 🌟 Collecting rare egg: " .. entry.rareName)
            local result = walkToEgg(entry.target, entry.color)
            if result == "done" then
                sendGenericWebhook(
                    Config.WEBHOOK_RARE_EGGS,
                    "🎉 RARE EGG COLLECTED!",
                    "Successfully collected: **" .. entry.rareName .. "**!",
                    65280,
                    getPingText(),
                    buildRarityFields(entry.rareName)
                )
            end
            task.wait(0.3)
        end
    end
end

-- ─────────────────────────────────────────────────────────────────────
-- QUEUE
-- ─────────────────────────────────────────────────────────────────────

local function pruneQueue()
    local alive = {}
    for _, e in ipairs(eggQueue) do
        if isAlive(e.target) then table.insert(alive, e) else queuedIds[e.id] = nil end
    end
    eggQueue = alive
end

local function releaseWalking()
    isWalking     = false
    currentTarget = nil
end

function processQueue()
    if not farmEnabled() or isWalking or #eggQueue == 0 then return end

    -- Process rare eggs first before touching normal queue
    if #rareEggQueue > 0 then
        task.spawn(processRareEggQueue)
        return
    end

    isWalking = true
    task.spawn(function()
        local hardTimer = task.delay(WALK_HARD_TIMEOUT, function() releaseWalking() end)
        pruneQueue()
        smartSortQueue()

        -- Auto-use items check
        pcall(tryAutoUseItems)
        -- Scan for rare eggs
        pcall(scanForRareEggs)

        local data = table.remove(eggQueue, 1)
        if data and queuedIds[data.id] then
            queuedIds[data.id] = nil
            currentTarget = data

            if isAlive(data.target) and farmEnabled() then
                respawnAndWait()
                local result = walkToEgg(data.target, data.color)

                if result == "interrupted" then
                    if isAlive(data.target) then
                        queuedIds[data.id] = true
                        table.insert(eggQueue, { target=data.target, color=data.color, id=data.id })
                        warn("[EggBot] Re-queued interrupted egg: " .. data.target.Name)
                    end
                elseif result == "fail" then
                    failCounts[data.id] = (failCounts[data.id] or 0) + 1
                    if failCounts[data.id] >= 3 then
                        warn("[EggBot] Auto-blacklisting " .. data.id)
                        BLACKLIST[data.target.Name] = true
                    end
                end
            end
        end

        task.cancel(hardTimer)
        releaseWalking()
        if farmEnabled() then task.wait(QUEUE_COOLDOWN) processQueue() end
    end)
end

function checkEgg(v)
    task.spawn(function()
        if not v or not (v:IsA("Model") or v:IsA("BasePart")) then return end
        task.wait(0.1)
        if not isAlive(v) then return end
        local name = v.Name
        if BLACKLIST[name] then return end
        local uid = name .. tostring(v)
        if queuedIds[uid] then return end

        -- Check excluded zone
        local pos = resolvePos(v)
        if pos and isPositionExcluded(pos) then return end

        local eggNum     = tonumber(string.match(name, "egg_(%d+)$"))
        local isPriority = PRIORITY_SET[name] == true
        local isPotion   = string.find(name, "potion", 1, true) ~= nil
        local eggColor

        if isPriority then eggColor = PRIORITY_COLOR
        elseif isPotion then eggColor = POTION_COLOR
        elseif eggNum then eggColor = EGG_COLORS[eggNum] or DEFAULT_COLOR
        else return end

        local hasPrompt = false
        for _, d in ipairs(v:GetDescendants()) do
            if d:IsA("ProximityPrompt") then hasPrompt = true break end
        end
        if not hasPrompt then return end

        -- Skip already collected
        if isEggCollected(v) then return end

        local entry = { target=v, color=eggColor, id=uid }
        queuedIds[uid] = true
        table.insert(eggQueue, entry)

        checkShouldInterrupt(entry)

        if farmEnabled() then processQueue() end
    end)
end

player.CharacterAdded:Connect(function()
    task.wait(1)
    stuckCheckCount    = 0
    isWalking          = false
    isCollectingPickup = false
    interruptWalk      = false
    currentTarget      = nil
    if isRunning() then processQueue() end
end)

